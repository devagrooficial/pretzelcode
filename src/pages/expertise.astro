  <Footer />

  <script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    // Register once at module level — safe, runs only once
    gsap.registerPlugin(ScrollTrigger);

    function initPage() {
      // Kill any stale ScrollTrigger instances from a previous navigation
      ScrollTrigger.getAll().forEach(t => t.kill());

      // ── 1. Timeline spine (fills green progress line on scroll) ──────────
      gsap.to("#spine-progress", {
        scaleY: 1,
        ease: "none",
        scrollTrigger: {
          trigger: "#methodology-timeline",
          start: "top center",
          end: "bottom center",
          scrub: true
        }
      });

      // ── 2. Node reveal animations ─────────────────────────────────────────
      const nodes = gsap.utils.toArray<HTMLElement>(".timeline-node");

      nodes.forEach((node) => {
        const indicator = node.querySelector(".node-indicator");

        // Ensure nodes start invisible so the animation can reveal them
        gsap.set(node, { opacity: 0, y: 48 });

        ScrollTrigger.create({
          trigger: node,
          start: "top 65%",
          onEnter: () => {
            gsap.to(node, { opacity: 1, y: 0, duration: 0.8, ease: "power3.out" });
            if (indicator) {
              gsap.to(indicator, {
                borderColor: "#10B981",
                backgroundColor: "#050505",
                color: "#10B981",
                boxShadow: "0 0 20px rgba(16, 185, 129, 0.4)",
                duration: 0.5
              });
            }
          },
          onLeaveBack: () => {
            gsap.to(node, { opacity: 0, y: 48, duration: 0.5, ease: "power3.inOut" });
            if (indicator) {
              gsap.to(indicator, {
                borderColor: "#222",
                backgroundColor: "#050505",
                color: "white",
                boxShadow: "none",
                duration: 0.5
              });
            }
          }
        });
      });

      // Refresh ScrollTrigger after DOM is fully settled
      ScrollTrigger.refresh();

      // ── 3. Watermark hover logic ──────────────────────────────────────────
      const triggers = document.querySelectorAll('.tech-trigger');
      const container = document.getElementById('matrix-watermark-container');
      const supabaseWm = document.getElementById('wm-supabase');
      const reactWm = document.getElementById('wm-react');

      triggers.forEach(trigger => {
        trigger.addEventListener('mouseenter', (e) => {
          const tech = (e.target as HTMLElement).getAttribute('data-tech');
          if (!container) return;

          container.classList.remove('opacity-0');
          container.classList.add('opacity-100');

          if (tech === 'supabase' && supabaseWm) {
            supabaseWm.classList.remove('opacity-0', 'scale-95');
            supabaseWm.classList.add('opacity-10', 'scale-100');
          } else if (tech === 'react' && reactWm) {
            reactWm.classList.remove('opacity-0', 'scale-95');
            reactWm.classList.add('opacity-10', 'scale-100');
          }
        });

        trigger.addEventListener('mouseleave', (e) => {
          if (!container) return;
          const tech = (e.target as HTMLElement).getAttribute('data-tech');

          container.classList.remove('opacity-100');
          container.classList.add('opacity-0');

          if (tech === 'supabase' && supabaseWm) {
            supabaseWm.classList.add('opacity-0', 'scale-95');
            supabaseWm.classList.remove('opacity-10', 'scale-100');
          } else if (tech === 'react' && reactWm) {
            reactWm.classList.add('opacity-0', 'scale-95');
            reactWm.classList.remove('opacity-10', 'scale-100');
          }
        });
      });
    }

    // Runs on first load AND every Astro SPA page transition
    document.addEventListener('astro:page-load', initPage);
  </script>
</Layout>

