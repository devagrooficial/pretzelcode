---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <Navbar />
  
  <!-- The Console (Hero Section) -->
  <section class="relative w-full bg-[#050505] overflow-hidden min-h-[600px] flex items-center border-b border-[#1A1A1A]">
    <!-- Perspective Grid Background -->
    <div class="absolute inset-0 z-0 pointer-events-none flex items-end justify-center [perspective:1000px]">
      <!-- The isometric grid -->
      <div class="w-[300%] md:w-[200%] h-[300%] absolute bottom-[-100%] md:bottom-[-80%] bg-[linear-gradient(to_right,#ffffff08_1px,transparent_1px),linear-gradient(to_bottom,#ffffff08_1px,transparent_1px)] bg-[size:40px_40px] [transform:rotateX(75deg)] [mask-image:linear-gradient(to_top,black_5%,transparent_60%)] opacity-80"></div>
    </div>
    
    <!-- Hero Container -->
    <div class="relative z-10 w-full max-w-7xl mx-auto px-6 py-24 md:py-32 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      
      <!-- Left: Typography -->
      <div class="flex flex-col items-start pr-0 md:pr-12">
        <div class="text-primary font-semibold tracking-widest uppercase text-sm mb-4">Engineered for Scale</div>
        
        <h1 class="text-5xl md:text-7xl lg:text-[8rem] font-medium tracking-tighter leading-[1.05] text-white">
          We build for you what we build for ourselves.
        </h1>
        <p class="text-lg md:text-xl text-neutral-400 max-w-2xl mx-auto tracking-normal leading-relaxed mt-6">
          SaaS, Mobile, and Web specialists. Data-driven architecture, process automation, and full-stack development at Silicon Valley standards.
        </p>
      </div>

      <!-- Right: SVG Network Node Graphic -->
      <div class="relative w-full h-80 md:h-[450px] flex items-center justify-center">
        <!-- Flashing radial accent behind the nodes -->
        <div class="absolute w-64 h-64 bg-emerald-500/10 blur-[80px] rounded-full"></div>
        
        <svg viewBox="0 0 400 400" fill="none" class="w-full h-full text-gray-500 relative z-10">
           <style>
              .data-path { stroke-dasharray: 4 8; stroke-linecap: round; animation: flow 3s linear infinite; }
              @keyframes flow { 100% { stroke-dashoffset: -24; } }
           </style>

           <!-- Core Database Hub -->
           <circle cx="200" cy="200" r="40" fill="#0A0A0A" stroke="#1A1A1A" stroke-width="2"/>
           <circle cx="200" cy="200" r="16" fill="transparent" stroke="#10B981" stroke-width="2" class="animate-ping" style="animation-duration: 4s;"/>
           <circle cx="200" cy="200" r="16" fill="#10B981"/>
           
           <!-- Links radiating out -->
           <path d="M 200 160 L 200 80" stroke="#222" stroke-width="1.5"/>
           <path class="data-path" d="M 200 160 L 200 80" stroke="#10B981" stroke-width="1.5"/>

           <path d="M 240 200 L 320 200" stroke="#222" stroke-width="1.5"/>
           <path class="data-path" d="M 240 200 L 320 200" stroke="#10B981" stroke-width="1.5"/>

           <path d="M 160 200 L 80 200" stroke="#222" stroke-width="1.5"/>
           <path class="data-path" d="M 160 200 L 80 200" stroke="#10B981" stroke-width="1.5"/>

           <path d="M 170 230 L 120 300" stroke="#222" stroke-width="1.5"/>
           <path class="data-path" d="M 170 230 L 120 300" stroke="#10B981" stroke-width="1.5"/>

           <path d="M 230 230 L 280 300" stroke="#222" stroke-width="1.5"/>
           <path class="data-path" d="M 230 230 L 280 300" stroke="#10B981" stroke-width="1.5"/>
           
           <!-- Outer Nodes (Servers/Webhooks/Mobile) -->
           <rect x="180" y="50" width="40" height="30" rx="4" fill="#0A0A0A" stroke="#222" stroke-width="1.5"/>
           <rect x="320" y="185" width="30" height="30" rx="4" fill="#0A0A0A" stroke="#222" stroke-width="1.5"/>
           <rect x="50" y="185" width="30" height="30" rx="4" fill="#0A0A0A" stroke="#222" stroke-width="1.5"/>
           <rect x="90" y="300" width="40" height="30" rx="4" fill="#0A0A0A" stroke="#222" stroke-width="1.5"/>
           <rect x="270" y="300" width="40" height="30" rx="4" fill="#0A0A0A" stroke="#222" stroke-width="1.5"/>
        </svg>
      </div>

    </div>
  </section>

  <main class="flex-1 w-full max-w-7xl mx-auto px-6 py-12 md:py-24 flex flex-col gap-16">

    <!-- Expertise Horizontal Grid -->
    <section class="grid grid-cols-1 md:grid-cols-3 gap-6 w-full relative z-10 mt-[-40px]">
      <!-- Box 1: SaaS Development -->
      <div class="rounded-[24px] border border-[#1A1A1A] bg-[#050505] p-10 flex flex-col group transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_10px_30px_rgba(255,255,255,0.03)] hover:border-gray-700">
        <div class="w-16 h-16 mb-8 rounded-2xl bg-[#000000] border border-[#1A1A1A] flex items-center justify-center relative overflow-hidden group-hover:bg-blue-500/5 transition-colors">
          <div class="absolute inset-0 bg-blue-500/10 blur-xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-8 h-8 text-blue-400 relative z-10 transition-transform group-hover:scale-110 duration-500 drop-shadow-[0_0_12px_rgba(96,165,250,0.5)]">
            <rect x="2" y="2" width="20" height="6" rx="2"></rect>
            <rect x="2" y="9" width="20" height="6" rx="2"></rect>
            <rect x="2" y="16" width="20" height="6" rx="2"></rect>
            <line x1="6" y1="5" x2="6.01" y2="5"></line>
            <line x1="6" y1="12" x2="6.01" y2="12"></line>
            <line x1="6" y1="19" x2="6.01" y2="19"></line>
          </svg>
        </div>
        <h3 class="text-2xl font-bold text-white mb-3">SaaS Development</h3>
        <p class="text-gray-400 text-sm md:text-base mb-8 leading-relaxed">
          Robust multi-tenant architecture. From database logic and auth to integrated Stripe billing. Focused on MRR and scalability from Day 1.
        </p>
        <div class="mt-auto">
          <button class="text-blue-400 text-sm font-medium tracking-wide flex items-center gap-2 group-hover:text-blue-300 transition-colors">
            Core Infrastructure
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
          </button>
        </div>
      </div>

      <!-- Box 2: Mobile App Development -->
      <div class="rounded-[24px] border border-[#1A1A1A] bg-[#050505] p-10 flex flex-col group transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_10px_30px_rgba(255,255,255,0.03)] hover:border-gray-700">
        <div class="w-16 h-16 mb-8 rounded-2xl bg-[#000000] border border-[#1A1A1A] flex items-center justify-center relative overflow-hidden group-hover:bg-emerald-500/5 transition-colors">
          <div class="absolute inset-0 bg-emerald-500/10 blur-xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-8 h-8 text-emerald-400 relative z-10 transition-transform group-hover:-translate-y-1 duration-500 drop-shadow-[0_0_12px_rgba(16,185,129,0.5)]">
            <rect x="5" y="2" width="14" height="20" rx="2"></rect>
            <path d="M12 18h.01"></path>
          </svg>
          <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-500 delay-100">
            <div class="w-6 h-4 bg-[#111] border border-[#222] shadow-[0_4px_12px_rgba(0,0,0,0.5)] rounded transform translate-x-3 -translate-y-1"></div>
          </div>
        </div>
        <h3 class="text-2xl font-bold text-white mb-3">Mobile Apps</h3>
        <p class="text-gray-400 text-sm md:text-base mb-8 leading-relaxed">
          High-performance native and cross-platform apps. Responsive interfaces, complex API integrations, and App Store/Google Play deployment.
        </p>
        <div class="mt-auto">
          <button class="text-emerald-400 text-sm font-medium tracking-wide flex items-center gap-2 group-hover:text-emerald-300 transition-colors">
            Native & Cross-Platform
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
          </button>
        </div>
      </div>

      <!-- Box 3: Web Platforms -->
      <div class="rounded-[24px] border border-[#1A1A1A] bg-[#050505] p-10 flex flex-col group transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_10px_30px_rgba(255,255,255,0.03)] hover:border-gray-700">
        <div class="w-16 h-16 mb-8 rounded-2xl bg-[#000000] border border-[#1A1A1A] flex items-center justify-center relative overflow-hidden group-hover:bg-violet-500/5 transition-colors">
          <div class="absolute inset-0 bg-violet-500/10 blur-xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          
          <svg viewBox="0 0 24 24" fill="none" class="w-8 h-8 relative z-10 transition-transform group-hover:scale-105 duration-500 drop-shadow-[0_0_12px_rgba(139,92,246,0.5)]">
             <rect x="2" y="4" width="20" height="16" rx="2" stroke="currentColor" stroke-width="1.5" class="text-violet-400"/>
             <path d="M2 8h20" stroke="currentColor" stroke-width="1.5" class="text-violet-400" />
             <circle cx="6" cy="6" r="1" fill="currentColor" class="text-violet-400"/>
             <circle cx="9" cy="6" r="1" fill="currentColor" class="text-violet-400"/>
             <path d="M4 16 l4-4 l4 2 l6-6" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" class="text-violet-400" />
          </svg>
        </div>
        <h3 class="text-2xl font-bold text-white mb-3">Web Platforms</h3>
        <p class="text-gray-400 text-sm md:text-base mb-8 leading-relaxed">
          B2B portals, operational dashboards, and ultra-fast institutional sites for brands positioning as technology leaders.
        </p>
        <div class="mt-auto">
           <button class="text-violet-400 text-sm font-medium tracking-wide flex items-center gap-2 group-hover:text-violet-300 transition-colors">
            Frontend Architecture
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
          </button>
        </div>
      </div>
    </section>

    <!-- Authority Architecture Grid (Row 2) -->
    <section class="grid grid-cols-1 lg:grid-cols-4 gap-6 w-full">
      
      <!-- Box 4: The Stack Matrix -->
      <div class="lg:col-span-3 rounded-[24px] border border-[#1A1A1A] bg-[#050505] p-10 flex flex-col group transition-all duration-300 hover:border-gray-700 relative overflow-hidden">
        
        <!-- SVG Watermarks Container -->
        <div class="absolute inset-0 pointer-events-none z-0 flex items-center justify-center lg:justify-end lg:pr-32 opacity-0 transition-opacity duration-700" id="matrix-watermark-container">
           <!-- Supabase SVG -->
           <svg id="wm-supabase" class="absolute w-64 h-64 opacity-0 scale-95 transition-all duration-700 drop-shadow-[0_0_40px_rgba(62,207,142,0.3)]" viewBox="0 0 214 214" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M117.82 23.3642C112.016 16.7115 101.077 20.803 101.077 29.6105V97.359H24.3217C15.2285 97.359 10.5147 108.204 16.7584 114.869L96.2625 199.664C102.046 205.833 112.784 201.761 112.784 193.264V122.956H189.658C198.814 122.956 203.541 112.011 197.194 105.352L117.82 23.3642Z" fill="#3ECF8E"/></svg>
           <!-- React SVG -->
           <svg id="wm-react" class="absolute w-64 h-64 opacity-0 scale-95 transition-all duration-700 drop-shadow-[0_0_40px_rgba(97,218,251,0.3)]" viewBox="-11.5 -10.23174 23 20.46348" xmlns="http://www.w3.org/2000/svg">
             <circle cx="0" cy="0" r="2.05" fill="#61dafb"/>
             <g stroke="#61dafb" stroke-width="1" fill="none">
               <ellipse rx="11" ry="4.2"/>
               <ellipse rx="11" ry="4.2" transform="rotate(60)"/>
               <ellipse rx="11" ry="4.2" transform="rotate(120)"/>
             </g>
           </svg>
        </div>

        <h3 class="text-2xl font-bold text-white mb-8 relative z-10">The Stack Matrix</h3>
        
        <div class="flex flex-col lg:flex-row gap-12 items-center relative z-10">
          <!-- Stack Tags Visual -->
          <div class="flex-1 flex flex-col gap-4 w-full">
            <div class="flex flex-col sm:flex-row sm:items-center gap-3 p-4 rounded-xl bg-[#0A0A0A] border border-[#1A1A1A]">
              <div class="flex items-center gap-2 w-32">
                <span class="w-2 h-2 rounded-full bg-blue-500 animate-pulse"></span>
                <span class="text-xs font-mono tracking-widest text-gray-400">BACKEND</span>
              </div>
              <div class="flex flex-wrap gap-2">
                <span class="px-2 py-1 text-xs rounded bg-[#111] text-gray-300 border border-[#222]">Python</span>
                <span class="px-2 py-1 text-xs rounded bg-[#111] text-gray-300 border border-[#222]">Node.js</span>
                <span class="px-2 py-1 text-xs rounded bg-[#111] text-gray-300 border border-[#222] transition-colors hover:bg-[#0A0A0A] hover:text-white cursor-crosshair tech-trigger" data-tech="supabase">Supabase</span>
              </div>
            </div>
            
            <div class="flex flex-col sm:flex-row sm:items-center gap-3 p-4 rounded-xl bg-[#0A0A0A] border border-[#1A1A1A]">
              <div class="flex items-center gap-2 w-32">
                <span class="w-2 h-2 rounded-full bg-violet-500 animate-pulse" style="animation-delay: 200ms"></span>
                <span class="text-xs font-mono tracking-widest text-gray-400">FRONTEND</span>
              </div>
              <div class="flex flex-wrap gap-2">
                <span class="px-2 py-1 text-xs rounded bg-[#111] text-gray-300 border border-[#222] transition-colors hover:bg-[#0A0A0A] hover:text-white cursor-crosshair tech-trigger" data-tech="react">React Native</span>
                <span class="px-2 py-1 text-xs rounded bg-[#111] text-gray-300 border border-[#222]">Next.js</span>
                <span class="px-2 py-1 text-xs rounded bg-[#111] text-gray-300 border border-[#222]">Astro</span>
              </div>
            </div>

            <div class="flex flex-col sm:flex-row sm:items-center gap-3 p-4 rounded-xl bg-[#0A0A0A] border border-[#1A1A1A]">
              <div class="flex items-center gap-2 w-32">
                <span class="w-2 h-2 rounded-full bg-rose-500 animate-pulse" style="animation-delay: 400ms"></span>
                <span class="text-xs font-mono tracking-widest text-gray-400">OPERATIONS</span>
              </div>
              <div class="flex flex-wrap gap-2">
                <span class="px-2 py-1 text-xs rounded bg-[#111] text-gray-300 border border-[#222]">Microservices</span>
                <span class="px-2 py-1 text-xs rounded bg-[#111] text-gray-300 border border-[#222]">Stripe</span>
              </div>
            </div>
          </div>

          <!-- Copy right side -->
          <div class="flex-1">
            <p class="text-gray-400 text-lg leading-relaxed">
              We deploy <span class="text-white font-medium">custom backend microservices in Python or Node.js</span>, chosen based on the complexity and scale of each project, plus event-driven automations running silently in the background. We focus intensely on reducing operational overhead and letting you scale your core product matrix without friction.
            </p>
          </div>
        </div>
      </div>

      <!-- Box 5: Skin in the Game -->
      <div class="lg:col-span-1 rounded-[24px] border border-[#1A1A1A] bg-[#030303] p-10 flex flex-col group relative overflow-hidden transition-all duration-300 hover:border-[#333]">
        <!-- SVG Noise / Metal Texture -->
        <div class="absolute inset-0 opacity-20 mix-blend-overlay pointer-events-none" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noiseFilter%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.8%22 numOctaves=%223%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noiseFilter)%22/%3E%3C/svg%3E');"></div>
        
        <div class="relative z-10 h-full flex flex-col">
          <div class="w-12 h-12 mb-8 rounded-full bg-[#111] border border-[#222] flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-5 h-5 text-gray-300"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
          </div>
          <h3 class="text-2xl font-bold text-white mb-4">Skin in the Game</h3>
          <p class="text-gray-400 text-sm leading-relaxed mt-auto">
             <strong class="text-white font-medium block mb-3">We are a SaaS Factory first.</strong>
             We deploy, test, and scale architectures on our own internal products before ever suggesting them to our clients. Validated market know-how.
          </p>
        </div>
      </div>

    </section>

    <!-- Methodology Timeline (GSAP ScrollTrigger) -->
    <section class="w-full mt-24 mb-12 relative flex flex-col items-center">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-5xl font-bold text-white mb-4">The Methodology</h2>
        <p class="text-gray-400">Our sequential blueprint for building unbreakable platforms.</p>
      </div>

      <!-- Timeline Container -->
      <div class="relative w-full max-w-4xl mx-auto" id="methodology-timeline">
        <!-- The Spine -->
        <div class="absolute left-6 md:left-1/2 top-0 bottom-0 w-[2px] bg-[#111] transform md:-translate-x-1/2 rounded-full overflow-hidden">
          <div id="spine-progress" class="w-full h-full bg-emerald-500 origin-top scale-y-0 shadow-[0_0_10px_#10B981]"></div>
        </div>

        <!-- Node 1 -->
        <div class="timeline-node relative flex items-center justify-between w-full mb-24 opacity-0 translate-y-12 pl-16 md:pl-0">
          <div class="hidden md:block w-[45%] text-right pr-12">
            <h3 class="text-2xl font-bold text-white mb-2">Architecture & Blueprint</h3>
            <p class="text-gray-400 text-sm leading-relaxed">Database modeling, system architecture mapping, and UI/UX wireframing to solidify the core structure before droping a single line of code.</p>
          </div>
          <!-- Center Node Indicator -->
          <div class="absolute left-6 md:left-1/2 transform -translate-x-1/2 w-10 h-10 rounded-full border border-[#222] bg-[#050505] flex items-center justify-center z-10 transition-all duration-500 node-indicator">
            <span class="text-sm font-mono font-bold text-white">1</span>
          </div>
          <div class="w-full md:w-[45%] md:pl-12">
            <div class="md:hidden">
              <h3 class="text-2xl font-bold text-white mb-2">Architecture & Blueprint</h3>
              <p class="text-gray-400 text-sm leading-relaxed">Database modeling, system architecture mapping, and UI/UX wireframing to solidify the core structure before droping a single line of code.</p>
            </div>
            <!-- Visual mock -->
            <div class="w-full h-32 rounded-[16px] border border-[#1A1A1A] bg-[#0A0A0A] p-4 flex flex-col justify-between hidden md:flex opacity-60 hover:opacity-100 transition-opacity">
               <div class="h-2 w-1/3 bg-[#222] rounded-full"></div>
               <div class="flex gap-2">
                 <div class="flex-1 h-12 border border-[#222] rounded bg-[#111]"></div>
                 <div class="flex-1 h-12 border border-[#222] rounded bg-[#111]"></div>
               </div>
            </div>
          </div>
        </div>

        <!-- Node 2 -->
        <div class="timeline-node relative flex items-center justify-between w-full mb-24 opacity-0 translate-y-12 pl-16 md:pl-0">
          <div class="w-full md:w-[45%] md:text-right md:pr-12">
            <div class="md:hidden">
              <h3 class="text-2xl font-bold text-white mb-2">The Backend Core</h3>
              <p class="text-gray-400 text-sm leading-relaxed">Business logic, APIs, and automation development in Python or Node.js, chosen based on project complexity. We build the engine that powers the front-facing products securely and efficiently.</p>
            </div>
            <!-- Visual mock -->
            <div class="w-full h-32 rounded-[16px] border border-[#1A1A1A] bg-[#0A0A0A] p-4 flex flex-col gap-3 hidden md:flex opacity-60 hover:opacity-100 transition-opacity items-end">
               <div class="h-2 w-2/3 bg-[#222] rounded-full"></div>
               <div class="h-2 w-1/2 bg-[#222] rounded-full"></div>
               <div class="h-2 w-3/4 bg-[#222] rounded-full"></div>
               <div class="h-2 w-1/3 bg-blue-500/50 rounded-full mt-auto"></div>
            </div>
          </div>
          <!-- Center Node Indicator -->
          <div class="absolute left-6 md:left-1/2 transform -translate-x-1/2 w-10 h-10 rounded-full border border-[#222] bg-[#050505] flex items-center justify-center z-10 transition-all duration-500 node-indicator">
            <span class="text-sm font-mono font-bold text-white">2</span>
          </div>
          <div class="hidden md:block w-[45%] pl-12">
             <h3 class="text-2xl font-bold text-white mb-2">The Backend Core</h3>
             <p class="text-gray-400 text-sm leading-relaxed">Business logic, APIs, and automation development in Python or Node.js, chosen based on project complexity. We build the engine that powers the front-facing products securely and efficiently.</p>
          </div>
        </div>

        <!-- Node 3 -->
        <div class="timeline-node relative flex items-center justify-between w-full mb-24 opacity-0 translate-y-12 pl-16 md:pl-0">
          <div class="hidden md:block w-[45%] text-right pr-12">
            <h3 class="text-2xl font-bold text-white mb-2">Frontend Assembly</h3>
            <p class="text-gray-400 text-sm leading-relaxed">Connecting the stable backend to high-end interfaces. We use Astro, React, and React Native to build responsive, stunning client facades.</p>
          </div>
          <!-- Center Node Indicator -->
          <div class="absolute left-6 md:left-1/2 transform -translate-x-1/2 w-10 h-10 rounded-full border border-[#222] bg-[#050505] flex items-center justify-center z-10 transition-all duration-500 node-indicator">
            <span class="text-sm font-mono font-bold text-white">3</span>
          </div>
          <div class="w-full md:w-[45%] md:pl-12">
            <div class="md:hidden">
              <h3 class="text-2xl font-bold text-white mb-2">Frontend Assembly</h3>
              <p class="text-gray-400 text-sm leading-relaxed">Connecting the stable backend to high-end interfaces. We use Astro, React, and React Native to build responsive, stunning client facades.</p>
            </div>
            <!-- Visual mock -->
            <div class="w-full h-32 rounded-[16px] border border-[#1A1A1A] bg-[#0A0A0A] p-4 flex flex-col hidden md:flex opacity-60 hover:opacity-100 transition-opacity relative overflow-hidden">
               <div class="absolute top-4 left-4 right-4 h-6 bg-[#111] border border-[#222] rounded flex items-center px-2"><span class="w-2 h-2 rounded-full bg-rose-500"></span></div>
               <div class="absolute bottom-4 left-4 w-12 h-12 bg-emerald-500/20 rounded border border-emerald-500/50"></div>
            </div>
          </div>
