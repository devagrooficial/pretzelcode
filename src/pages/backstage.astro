---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <Navbar />
  
  <!-- Backstage Hero: The Gate -->
  <section class="relative w-full bg-[#000000] border-b border-[#1A1A1A] overflow-hidden flex flex-col items-center justify-center pt-32 pb-24 md:pt-40 md:pb-32 px-6">
    <!-- Dark Metallic Spotlight Sheen -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-4xl h-96 bg-[radial-gradient(ellipse_at_top,rgba(255,255,255,0.06)_0%,transparent_70%)] pointer-events-none"></div>

    <div class="relative z-10 flex flex-col items-center text-center max-w-3xl">
      <!-- Badge -->
      <div class="text-primary font-semibold tracking-widest uppercase text-sm mb-4">Restricted Access</div>

      <!-- Headlines -->
      <h1 class="text-5xl md:text-7xl lg:text-[8rem] font-medium tracking-tighter leading-[1.05] text-white">Peek inside the SaaS Factory.</h1>
      <p class="text-lg md:text-xl text-neutral-400 max-w-2xl mx-auto tracking-normal leading-relaxed mt-6 mb-10">
        Real-time access to our production line. Track metrics, valuations, architectural decisions, and get early (Alpha) access to our assets.
      </p>

      <!-- Primary CTA -->
      <button class="px-8 py-4 bg-primary text-white font-bold rounded-full hover:bg-primary-hover transition-all duration-300 shadow-[0_0_20px_var(--color-primary-glow)] hover:shadow-[0_0_35px_var(--color-primary-glow)] hover:-translate-y-0.5">
        Unlock the Vault - $19/mo
      </button>

      <!-- Trust Subtext -->
      <div class="mt-6 flex items-center justify-center gap-3 text-xs text-gray-600 font-medium">
        <span>Cancel anytime. Billed via Stripe.</span>
        <!-- Minimalist Mastercard abstract -->
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" class="opacity-80">
          <circle cx="9" cy="12" r="5" fill="#555"/>
          <circle cx="15" cy="12" r="5" fill="#555" fill-opacity="0.8"/>
        </svg>
      </div>
    </div>
  </section>

  <main class="flex-1 w-full max-w-7xl mx-auto px-6 py-12 md:py-24 flex flex-col gap-12">

    <!-- Dashboard Preview Layout (Bento Grid) -->
    <div class="w-full grid grid-cols-1 md:grid-cols-12 gap-6 relative z-0">
        
        <!-- Box 1 (6 col): NexusFlow Dashboard -->
        <div class="col-span-1 md:col-span-6 rounded-[24px] border border-[#1A1A1A] bg-[#050505] p-6 md:p-10 relative overflow-hidden flex flex-col h-[340px]">
           <div class="absolute inset-0 z-0 noise-bg opacity-[0.03]"></div>
           
           <div class="relative z-10 flex justify-between items-start mb-6">
              <h3 class="text-xl font-bold text-white flex items-center gap-3">
                 <span class="w-2 h-2 rounded-full bg-emerald-500 shadow-[0_0_8px_#10B981]"></span>
                 NexusFlow Dashboard
              </h3>
           </div>

           <!-- Synthetic Dashboard Data -->
           <div class="relative flex-1 bg-[#090909] border border-[#1A1A1A] rounded-[16px] p-6 overflow-hidden flex flex-col justify-end">
              <!-- Raw data mockups -->
              <div class="w-full flex justify-between items-end mb-4 opacity-50">
                <div>
                   <p class="text-xs text-gray-500 uppercase tracking-widest font-mono mb-1">Current Valuation</p>
                   <p class="text-3xl font-mono text-white">$14,250,500</p>
                </div>
                <div class="text-right">
                   <p class="text-xs text-gray-500 uppercase tracking-widest font-mono mb-1">Real-Time MRR</p>
                   <p class="text-xl font-mono text-emerald-400">$340K</p>
                </div>
              </div>
              
              <!-- Simulated Chart Abstract -->
              <div class="w-full h-16 border-t border-dashed border-[#222] relative opacity-40">
                 <svg class="absolute bottom-0 w-full h-12" preserveAspectRatio="none" viewBox="0 0 100 100">
                    <path d="M0,100 L0,80 C20,90 40,30 60,70 C80,110 90,20 100,10 L100,100 Z" fill="rgba(16,185,129,0.1)" stroke="#10B981" stroke-width="2"/>
                 </svg>
              </div>

              <!-- Paywall Blur Lock -->
              <div class="absolute inset-0 bg-[#050505]/40 backdrop-blur-[6px] z-20 flex flex-col items-center justify-center border border-[#1A1A1A]/50 rounded-[16px] transition-all duration-300 hover:bg-[#050505]/30">
                 <div class="w-10 h-10 rounded-full bg-[#111111] border border-[#222222] flex items-center justify-center text-gray-400 mb-2 shadow-2xl">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect width="18" height="11" x="3" y="11" rx="2" ry="2"/>
                        <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                    </svg>
                 </div>
                 <span class="text-xs font-mono tracking-widest uppercase text-gray-500">Premium Metric</span>
              </div>
           </div>
        </div>

        <!-- Box 2 (6 col): VaultMetrics Engine -->
        <div class="col-span-1 md:col-span-6 rounded-[24px] border border-[#1A1A1A] bg-[#050505] p-6 md:p-10 relative overflow-hidden flex flex-col h-[340px]">
           <div class="absolute inset-0 z-0 noise-bg opacity-[0.03]"></div>
           
           <div class="relative z-10 flex justify-between items-start mb-6">
              <h3 class="text-xl font-bold text-white flex items-center gap-3">
                 <span class="w-2 h-2 rounded-full bg-blue-500 shadow-[0_0_8px_#3B82F6]"></span>
                 VaultMetrics Engine
              </h3>
           </div>

           <!-- Synthetic Dashboard Data -->
           <div class="relative flex-1 bg-[#090909] border border-[#1A1A1A] rounded-[16px] p-6 overflow-hidden flex flex-col justify-center">
              
              <div class="grid grid-cols-2 gap-4 h-full opacity-50">
                 <div class="bg-[#111] rounded-xl p-4 border border-[#222] flex flex-col justify-center">
                    <p class="text-xs text-gray-500 uppercase tracking-widest font-mono mb-2">Infra Load</p>
                    <p class="text-2xl font-mono text-white">42.8%</p>
                    <p class="text-xs text-gray-600 mt-1">Stable capacity</p>
                 </div>
                 <div class="bg-[#111] rounded-xl p-4 border border-[#222] flex flex-col justify-center">
                    <p class="text-xs text-gray-500 uppercase tracking-widest font-mono mb-2">Workspaces</p>
                    <p class="text-2xl font-mono text-blue-400">1,842</p>
                    <p class="text-xs text-gray-600 mt-1">Active nodes</p>
                 </div>
              </div>

              <!-- Paywall Blur Lock -->
              <div class="absolute inset-0 bg-[#050505]/40 backdrop-blur-[6px] z-20 flex flex-col items-center justify-center border border-[#1A1A1A]/50 rounded-[16px] transition-all duration-300 hover:bg-[#050505]/30">
                 <div class="w-10 h-10 rounded-full bg-[#111111] border border-[#222222] flex items-center justify-center text-gray-400 mb-2 shadow-2xl">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect width="18" height="11" x="3" y="11" rx="2" ry="2"/>
                        <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                    </svg>
                 </div>
                 <span class="text-xs font-mono tracking-widest uppercase text-gray-500">Premium Metric</span>
              </div>
           </div>
        </div>
        <!-- Box 3 (8 col): Work in Progress (Kanban) -->
        <div class="col-span-1 md:col-span-8 rounded-[24px] border border-[#1A1A1A] bg-[#050505] p-6 md:p-10 relative overflow-hidden flex flex-col min-h-[340px]">
           <div class="absolute inset-0 z-0 noise-bg opacity-[0.03]"></div>
           <div class="relative z-10 mb-6">
              <h3 class="text-xl font-bold text-white mb-1">Work in Progress</h3>
              <p class="text-sm text-gray-500">Live development pipeline</p>
           </div>
           
           <!-- Minimal Kanban Board -->
           <div class="relative z-10 flex-1 grid grid-cols-1 sm:grid-cols-2 gap-4">
              <!-- Column: In Dev -->
              <div class="bg-[#090909] border border-[#1A1A1A] rounded-[16px] p-4 flex flex-col opacity-60">
                 <h4 class="text-xs uppercase tracking-widest text-gray-500 mb-4 font-mono flex items-center gap-2">
                    <span class="w-1.5 h-1.5 bg-yellow-500 rounded-full"></span> In Dev
                 </h4>
                 <div class="w-full h-24 border border-[#222] rounded-lg border-dashed"></div>
              </div>

              <!-- Column: Beta Testing -->
              <div class="bg-[#090909] border border-[#1A1A1A] rounded-[16px] p-4 flex flex-col shadow-[0_0_30px_rgba(255,255,255,0.02)]">
                 <h4 class="text-xs uppercase tracking-widest text-gray-400 mb-4 font-mono flex items-center gap-2">
                    <span class="w-1.5 h-1.5 bg-emerald-500 rounded-full shadow-[0_0_5px_#10B981]"></span> Beta Testing
                 </h4>
                 <!-- Kanban Task Card -->
                 <div class="bg-[#111] border border-[#222] rounded-[12px] p-4 flex flex-col shadow-lg">
                    <span class="text-white font-medium mb-1">AuraSync App</span>
                    <span class="text-xs text-gray-500 mb-4">Mobile client stabilization</span>
                    <!-- Stack Tags -->
                    <div class="flex items-center gap-2">
                       <span class="bg-[#1A1A1A] text-gray-400 text-[10px] uppercase font-mono px-2 py-1 rounded border border-[#2A2A2A]">React Native</span>
                       <span class="bg-[#1A1A1A] text-gray-400 text-[10px] uppercase font-mono px-2 py-1 rounded border border-[#2A2A2A]">Supabase</span>
                    </div>
                 </div>
              </div>
           </div>
        </div>

        <!-- Box 4 (4 col): Tech Stack Telemetry -->
        <div class="col-span-1 md:col-span-4 rounded-[24px] border border-[#1A1A1A] bg-[#050505] p-6 md:p-10 relative overflow-hidden flex flex-col min-h-[340px]">
           <div class="absolute inset-0 z-0 noise-bg opacity-[0.03]"></div>
           <div class="relative z-10 mb-8">
              <h3 class="text-xl font-bold text-white mb-1">Telemetry</h3>
           </div>
           
           <!-- Server LEDs list -->
           <div class="relative z-10 flex-1 flex flex-col gap-6 justify-center">
              <div class="flex items-center justify-between border-b border-[#1A1A1A] pb-4">
                 <div class="flex items-center gap-3">
                    <span class="relative flex h-2.5 w-2.5">
                      <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                      <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-emerald-500"></span>
                    </span>
                    <span class="text-gray-300 font-medium">Hetzner Core</span>
                 </div>
                 <span class="text-xs text-emerald-500 font-mono border border-emerald-500/20 bg-emerald-500/10 px-2 py-0.5 rounded">ONLINE</span>
              </div>
              <div class="flex items-center justify-between">
                 <div class="flex items-center gap-3">
                    <span class="relative flex h-2.5 w-2.5">
                      <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75" style="animation-duration: 0.8s;"></span>
                      <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-emerald-500"></span>
                    </span>
                    <span class="text-gray-300 font-medium">Supabase DB</span>
                 </div>
                 <span class="text-xs text-gray-400 font-mono">40ms</span>
              </div>
           </div>
        </div>

        <!-- Box 5 (6 col): Founder's Notes -->
        <div class="col-span-1 md:col-span-6 rounded-[24px] border border-[#1A1A1A] bg-[#050505] p-6 md:p-10 relative overflow-hidden flex flex-col min-h-[280px]">
           <div class="absolute inset-0 z-0 noise-bg opacity-[0.03]"></div>
           <div class="relative z-10 mb-6">
              <h3 class="text-xl font-bold text-white mb-1 flex items-center gap-2">
                 <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gray-500"><path d="M4 17l6-6-6-6"/><path d="M12 19h8"/></svg>
                 Founder's Notes
              </h3>
           </div>
           
           <div class="relative z-10 flex-1 bg-[#090909] border border-[#1A1A1A] rounded-[16px] p-5 overflow-hidden flex flex-col justify-center">
              <pre class="whitespace-pre-wrap font-mono text-sm leading-relaxed text-gray-400">
<span class="text-emerald-500">&gt;</span> Updated Supabase caching strategy today.
<span class="text-emerald-500">&gt;</span> 40ms reduction on NexusFlow queries.
<span class="text-gray-600 mt-4 block">[System Optimized // ROOT]</span>
              </pre>
           </div>
        </div>

        <!-- Box 6 (6 col): Alpha Perks -->
        <div class="col-span-1 md:col-span-6 rounded-[24px] border border-[#1A1A1A] bg-[#050505] p-6 md:p-10 relative overflow-hidden flex flex-col justify-center min-h-[280px]">
           <div class="absolute inset-0 z-0 noise-bg opacity-[0.03]"></div>
           <!-- Accent Emerald Border Top -->
           <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-emerald-500 to-transparent"></div>
                      <div class="relative z-10">
               <h3 class="text-2xl font-bold text-white mb-4 tracking-tight">The Vault Access</h3>
               <p class="text-lg text-gray-400 font-light leading-relaxed max-w-sm">
                  Backstage members get an exclusive, unfiltered look into our codebase, revenue metrics, and architectural decisions before they hit the public market.
               </p>
            </div>
        </div>

    </div>
  </main>

  <!-- ── Alpha Perks Program ─────────────────────────────────────────── -->
  <section class="max-w-7xl mx-auto px-6 py-24">

    <!-- Header -->
    <div class="max-w-2xl">
      <span class="text-primary font-semibold tracking-widest text-sm uppercase mb-4 block">Client-Only Benefit</span>
      <h2 class="text-4xl md:text-5xl font-medium tracking-tighter text-white mb-6">The Alpha Perks Program.</h2>
      <p class="text-lg text-neutral-400 leading-relaxed">
        Reserved exclusively for partners who commission our engineering services or acquire our proprietary SaaS assets.
        You don't just get world-class code; you inherit our entire operational infrastructure.
      </p>
    </div>

    <!-- Benefits Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-16">

      <!-- Card 1 -->
      <div class="bg-[#050505] border border-[#1A1A1A] rounded-[24px] p-8 hover:border-primary/50 transition-colors duration-300 flex flex-col gap-5">
        <span class="text-primary font-mono font-semibold text-sm tracking-widest">01.</span>
        <div>
          <h3 class="text-xl font-semibold text-white mb-3 tracking-tight">Zero-Day Access</h3>
          <p class="text-neutral-500 text-sm leading-relaxed">
            1-year premium license to every new internal SaaS we ship. Use our tools to scale your own operations, on the house.
          </p>
        </div>
        <!-- Icon -->
        <div class="mt-auto pt-4 border-t border-[#111]">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-6 h-6 text-neutral-700">
            <path d="M13 10V3L4 14h7v7l9-11h-7z" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
      </div>

      <!-- Card 2 -->
      <div class="bg-[#050505] border border-[#1A1A1A] rounded-[24px] p-8 hover:border-primary/50 transition-colors duration-300 flex flex-col gap-5">
        <span class="text-primary font-mono font-semibold text-sm tracking-widest">02.</span>
        <div>
          <h3 class="text-xl font-semibold text-white mb-3 tracking-tight">The Automation Vault</h3>
          <p class="text-neutral-500 text-sm leading-relaxed">
            Complimentary integration of our private Python microservices. We automate your back-office so you can focus on growth.
          </p>
        </div>
        <div class="mt-auto pt-4 border-t border-[#111]">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-6 h-6 text-neutral-700">
            <path d="M4 17l6-6-6-6M12 19h8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
      </div>

      <!-- Card 3 -->
      <div class="bg-[#050505] border border-[#1A1A1A] rounded-[24px] p-8 hover:border-primary/50 transition-colors duration-300 flex flex-col gap-5">
        <span class="text-primary font-mono font-semibold text-sm tracking-widest">03.</span>
        <div>
          <h3 class="text-xl font-semibold text-white mb-3 tracking-tight">Priority Pipeline</h3>
          <p class="text-neutral-500 text-sm leading-relaxed">
            Direct, async Slack channel with our lead architects. No account managers. No support tickets. Just straight-to-the-source engineering.
          </p>
        </div>
        <div class="mt-auto pt-4 border-t border-[#111]">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-6 h-6 text-neutral-700">
            <circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/>
            <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/>
            <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
          </svg>
        </div>
      </div>

    </div>

    <!-- CTA Final -->
    <div class="mt-20 pt-16 border-t border-[#1A1A1A] flex flex-col md:flex-row items-center justify-between gap-8">
      <p class="text-neutral-400 text-lg max-w-md leading-relaxed">
        To unlock these perks, start by building with us.
      </p>
      <a
        href="/company"
        class="flex-shrink-0 px-8 py-4 bg-primary hover:bg-primary-hover text-white font-semibold rounded-full transition-colors duration-300 shadow-[0_0_20px_var(--color-primary-glow)] hover:shadow-[0_0_35px_var(--color-primary-glow)] hover:-translate-y-0.5"
      >
        Schedule an Architecture Audit
      </a>
    </div>

  </section>

  <Footer />
</Layout>
