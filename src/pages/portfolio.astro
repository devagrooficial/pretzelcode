---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const projects = [
  {
    name:   'NexusFlow',
    tag:    'B2B SaaS · Enterprise',
    desc:   'Enterprise search and monitoring engine built for heavy data processing.',
    tech:   'Python · Supabase · React',
    color:  '#3B82F6',   // blue
    glyph:  'NF',
  },
  {
    name:   'VaultMetrics',
    tag:    'Analytics · Automation',
    desc:   'Autonomous lead acquisition and workflow automation platform.',
    tech:   'Python Microservices · PostgreSQL',
    color:  '#10B981',   // emerald
    glyph:  'VM',
  },
  {
    name:   'AuraSync',
    tag:    'Mobile · Consumer',
    desc:   'Ultra-fluid native mobile experience engineered for continuous daily use.',
    tech:   'React Native · Node.js',
    color:  '#A78BFA',   // violet
    glyph:  'AS',
  },
];
---

<Layout>
  <Navbar />

  <!-- ── Hero ─────────────────────────────────────────────────────── -->
  <section class="relative w-full flex flex-col items-center justify-center py-32 md:py-44 text-center px-6 overflow-hidden">

    <!-- Subtle radial glow -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[300px] bg-primary/10 blur-[120px] rounded-full pointer-events-none -z-10"></div>

    <!-- Eyebrow -->
    <span class="text-primary font-semibold tracking-widest uppercase text-sm mb-6 block">The Archives</span>

    <!-- Headline -->
    <h1 class="text-5xl md:text-7xl lg:text-[7rem] font-medium tracking-tighter leading-[1.05] text-white mb-6">
      The Archives.
    </h1>

    <!-- Sub-headline -->
    <p class="text-lg md:text-xl text-neutral-400 max-w-2xl mx-auto tracking-normal leading-relaxed">
      A curated selection of high-performance digital assets engineered for scale.
    </p>
  </section>

  <!-- ── Portfolio Grid ─────────────────────────────────────────────── -->
  <main class="w-full max-w-7xl mx-auto px-6 pb-32">

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

      {projects.map((p) => (
        <div
          class="group overflow-hidden rounded-[24px] border border-[#1A1A1A] relative cursor-pointer h-[400px] bg-[#050505] transition-all duration-500 hover:border-[#2A2A2A] hover:-translate-y-1 hover:shadow-[0_32px_64px_rgba(0,0,0,0.5)]"
          data-project={p.name}
          data-desc={p.desc}
          data-tech={p.tech}
        >
          <!-- ── Abstract visual fill ── -->
          <div class="absolute inset-0 overflow-hidden">

            <!-- Grid pattern -->
            <div class="absolute inset-0 opacity-[0.04]"
              style={`background-image: linear-gradient(${p.color}33 1px, transparent 1px), linear-gradient(90deg, ${p.color}33 1px, transparent 1px); background-size: 40px 40px;`}>
            </div>

            <!-- Glyph watermark -->
            <div
              class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 text-[10rem] font-black tracking-tighter select-none transition-all duration-700 group-hover:scale-110 group-hover:opacity-20"
              style={`color: ${p.color}; opacity: 0.07;`}
            >
              {p.glyph}
            </div>

            <!-- Radial colour bloom on hover -->
            <div
              class="absolute bottom-0 right-0 w-[300px] h-[300px] rounded-full blur-[80px] opacity-0 group-hover:opacity-30 transition-opacity duration-700"
              style={`background: ${p.color};`}
            ></div>

          </div>

          <!-- ── Card content ── -->
          <div class="relative z-10 h-full flex flex-col justify-between p-8">

            <!-- Top: tag pill -->
            <div class="flex items-start justify-between">
              <span
                class="text-[10px] font-mono font-semibold tracking-widest uppercase px-3 py-1.5 rounded-full border"
                style={`color: ${p.color}; border-color: ${p.color}33; background: ${p.color}11;`}
              >
                {p.tag}
              </span>

              <!-- Arrow icon (appears on hover) -->
              <div
                class="w-9 h-9 rounded-full border border-[#1A1A1A] flex items-center justify-center text-neutral-700 opacity-0 group-hover:opacity-100 group-hover:border-[#333] group-hover:text-white transition-all duration-300 -translate-y-1 group-hover:translate-y-0"
              >
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4">
                  <path d="M7 17L17 7M17 7H7M17 7v10"/>
                </svg>
              </div>
            </div>

            <!-- Bottom: project name + meta -->
            <div>
              <!-- Description (slides up on hover) -->
              <p
                class="text-sm text-neutral-500 leading-relaxed mb-4 max-w-[240px] opacity-0 group-hover:opacity-100 translate-y-2 group-hover:translate-y-0 transition-all duration-400"
              >
                {p.desc}
              </p>

              <!-- Project name -->
              <h2 class="text-3xl font-semibold tracking-tight text-white mb-1">
                {p.name}
              </h2>

              <!-- Tech stack -->
              <span class="text-xs font-mono text-neutral-600 tracking-wide">
                {p.tech}
              </span>
            </div>

          </div>

          <!-- ── Bottom accent line ── -->
          <div
            class="absolute bottom-0 left-0 h-[2px] w-0 group-hover:w-full transition-all duration-500 ease-out rounded-b-[24px]"
            style={`background: linear-gradient(90deg, ${p.color}, transparent);`}
          ></div>

        </div>
      ))}

    </div>

    <!-- ── Secondary CTA ─────────────────────────────────────────────── -->
    <div class="flex flex-col items-center gap-6 mt-24 text-center">
      <p class="text-neutral-500 text-sm tracking-wide uppercase font-mono">Want to see more?</p>
      <div class="flex flex-wrap items-center justify-center gap-4">
        <a
          href="/company"
          class="px-8 py-3.5 rounded-full bg-primary hover:bg-primary-hover text-white font-semibold text-sm transition-colors duration-300"
        >
          Start a Project
        </a>
        <a
          href="/work"
          class="px-8 py-3.5 rounded-full bg-white/5 border border-white/10 text-white font-medium text-sm hover:bg-white/10 hover:border-white/20 transition-all duration-300"
        >
          Full Case Studies →
        </a>
      </div>
    </div>

  </main>


  <Footer />

  <!-- ── Project Modal ──────────────────────────────────────────────── -->
  <div
    id="project-modal"
    class="fixed inset-0 z-[200] flex items-center justify-center bg-black/90 backdrop-blur-xl p-4
           opacity-0 pointer-events-none transition-opacity duration-300"
    aria-modal="true"
    role="dialog"
    aria-label="Project details"
  >
    <!-- Modal container -->
    <div class="relative w-full max-w-5xl bg-[#050505] border border-[#1A1A1A] rounded-[24px] overflow-hidden flex flex-col max-h-[90vh]
                scale-95 transition-transform duration-300"
         id="modal-container">

      <!-- ── Close button ── -->
      <button
        id="close-modal"
        class="absolute top-5 right-5 z-10 w-10 h-10 rounded-full bg-white/5 border border-white/10
               flex items-center justify-center text-neutral-400 hover:text-white hover:bg-white/10
               hover:border-white/20 transition-all duration-200 focus:outline-none"
        aria-label="Close modal"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>

      <!-- ── Image area ── -->
      <div class="relative h-[40vh] md:h-[50vh] bg-[#0A0A0A] flex-shrink-0 overflow-hidden">
        <!-- Placeholder glyph (shown when no image) -->
        <div id="modal-glyph"
             class="absolute inset-0 flex items-center justify-center text-[8rem] font-black tracking-tighter select-none opacity-10"
             style="color: #fff;">
        </div>
        <!-- Grid overlay pattern -->
        <div id="modal-grid-pattern" class="absolute inset-0 opacity-[0.05]"></div>
        <!-- Colour bloom -->
        <div id="modal-bloom"
             class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[500px] h-[300px] rounded-full blur-[100px] opacity-30">
        </div>
        <img
          id="modal-image"
          src=""
          alt=""
          class="relative z-10 w-full h-full object-cover object-center hidden"
        />
      </div>

      <!-- ── Text content ── -->
      <div class="flex-1 overflow-y-auto p-8 md:p-10">

        <!-- Header row -->
        <div class="flex items-start justify-between mb-6">
          <div>
            <!-- Category tag -->
            <span id="modal-tag"
                  class="text-[10px] font-mono font-semibold tracking-widest uppercase px-3 py-1.5 rounded-full border mb-4 inline-block">
            </span>
            <!-- Title -->
            <h2 id="modal-title" class="text-4xl md:text-5xl font-medium tracking-tighter text-white leading-[1.05]"></h2>
          </div>
        </div>

        <!-- Description -->
        <p id="modal-desc" class="text-neutral-400 text-base leading-relaxed max-w-2xl mt-2 mb-8"></p>

        <!-- Tech stack chips -->
        <div class="mb-2">
          <p class="text-xs text-neutral-600 uppercase tracking-widest font-mono mb-3">Tech Stack</p>
          <div id="modal-tech" class="flex flex-wrap gap-2"></div>
        </div>

      </div>
    </div>
  </div>

  <script>
    // Project colour map (mirrors frontmatter)
    const projectMeta: Record<string, { color: string; glyph: string; tag: string }> = {
      'NexusFlow':    { color: '#3B82F6', glyph: 'NF', tag: 'B2B SaaS · Enterprise' },
      'VaultMetrics': { color: '#10B981', glyph: 'VM', tag: 'Analytics · Automation' },
      'AuraSync':     { color: '#A78BFA', glyph: 'AS', tag: 'Mobile · Consumer' },
    };

    document.addEventListener('astro:page-load', () => {
      const modal     = document.getElementById('project-modal') as HTMLElement | null;
      const container = document.getElementById('modal-container') as HTMLElement | null;
      const closeBtn  = document.getElementById('close-modal') as HTMLElement | null;

      if (!modal || !container || !closeBtn) return;

      // ── Helpers ──────────────────────────────────────────────────────
      function openModal(data: { project: string; desc: string; tech: string }) {
        const meta = projectMeta[data.project] ?? { color: '#ffffff', glyph: '?', tag: '' };

        // Populate fields
        const title   = document.getElementById('modal-title');
        const desc    = document.getElementById('modal-desc');
        const techEl  = document.getElementById('modal-tech');
        const tag     = document.getElementById('modal-tag');
        const glyph   = document.getElementById('modal-glyph');
        const bloom   = document.getElementById('modal-bloom');
        const pattern = document.getElementById('modal-grid-pattern');

        if (title)   title.textContent = data.project;
        if (desc)    desc.textContent  = data.desc;
        if (tag) {
          tag.textContent = meta.tag;
          tag.setAttribute('style',
            `color:${meta.color}; border-color:${meta.color}33; background:${meta.color}11;`);
        }
        if (glyph) {
          glyph.textContent = meta.glyph;
          glyph.style.color = meta.color;
        }
        if (bloom)   bloom.style.background   = meta.color;
        if (pattern) pattern.style.backgroundImage =
          `linear-gradient(${meta.color}33 1px,transparent 1px),` +
          `linear-gradient(90deg,${meta.color}33 1px,transparent 1px)`;
        if (pattern) pattern.style.backgroundSize = '40px 40px';

        // Tech chips
        if (techEl) {
          techEl.innerHTML = '';
          data.tech.split('·').forEach(t => {
            const chip = document.createElement('span');
            chip.textContent = t.trim();
            chip.className = 'px-3 py-1.5 rounded-full text-xs font-mono border border-[#1A1A1A] text-neutral-400 bg-white/[0.03]';
            techEl.appendChild(chip);
          });
        }

        // Animate open
        document.body.style.overflow = 'hidden';
        modal.classList.remove('opacity-0', 'pointer-events-none');
        modal.classList.add('opacity-100');
        container.classList.remove('scale-95');
        container.classList.add('scale-100');
      }

      function closeModal() {
        modal.classList.add('opacity-0', 'pointer-events-none');
        modal.classList.remove('opacity-100');
        container.classList.add('scale-95');
        container.classList.remove('scale-100');
        document.body.style.overflow = '';
      }

      // ── Wire card clicks ──────────────────────────────────────────────
      document.querySelectorAll<HTMLElement>('[data-project]').forEach(card => {
        card.addEventListener('click', () => {
          openModal({
            project: card.dataset.project ?? '',
            desc:    card.dataset.desc    ?? '',
            tech:    card.dataset.tech    ?? '',
          });
        });
      });

      // ── Close triggers ────────────────────────────────────────────────
      closeBtn.addEventListener('click', closeModal);

      // Backdrop click (outside container)
      modal.addEventListener('click', (e) => {
        if (e.target === modal) closeModal();
      });

      // Escape key
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeModal();
      });
    });
  </script>

</Layout>
