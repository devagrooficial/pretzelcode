---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

// FormPush.io brand accent
const accent = '#EC4899';

const metrics = [
  { value: '16',   label: 'Recurring customers',   note: 'Active paid subscriptions' },
  { value: '$15',  label: 'Per month, per customer', note: 'Simple flat pricing' },
  { value: '10/10', label: 'Phases completed',      note: 'Full lifecycle, zero handoffs' },
  { value: '$21K', label: 'Current asset valuation', note: 'Grows with every new subscriber' },
];

const screens = [
  {
    src: '/images/lp.png',
    alt: 'FormPush.io landing page — Turn your Notion table into a powerful web form',
    caption: 'Landing page — connect, select, customize, publish in four clicks.',
    wide: true,
  },
  {
    src: '/images/dashboard.png',
    alt: 'FormPush.io dashboard — connect your Notion workspace via official OAuth',
    caption: 'Dashboard — secure workspace connection via Notion’s official OAuth.',
    wide: false,
  },
  {
    src: '/images/settings.png',
    alt: 'FormPush.io settings — custom domains, webhooks, usage and audit logs',
    caption: 'Settings — custom domains, webhooks, usage tracking and full audit logs.',
    wide: false,
  },
];

const capabilities = [
  {
    title: 'Native Notion integration',
    desc: 'Users authorize via Notion’s official OAuth, pick a database, and every submission lands directly in their workspace. No Zapier, no clunky embeds.',
  },
  {
    title: 'Smart, elegant forms',
    desc: 'FormPush reads the database schema and generates a clean, branded web form automatically — custom colors, hidden internal properties, clean URL or iframe snippet.',
  },
  {
    title: 'Production-grade operations',
    desc: 'Custom domains, webhooks, usage limits, audit logs and zero-retention infrastructure. Built, deployed and operated as a real product company would.',
  },
];
---

<Layout>
  <Navbar />

  <!-- ── Hero ─────────────────────────────────────────────────────── -->
  <section class="relative w-full flex flex-col items-center justify-center py-28 md:py-40 text-center px-6 overflow-hidden">

    <!-- Subtle radial glow -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[300px] blur-[120px] rounded-full pointer-events-none -z-10 opacity-15" style={`background: ${accent};`}></div>

    <!-- Eyebrow -->
    <span class="text-primary font-semibold tracking-widest uppercase text-sm mb-6 block">Portfolio · Flagship Case Study</span>

    <!-- Live badge -->
    <span class="inline-flex items-center gap-2 text-[11px] font-mono font-semibold tracking-widest uppercase px-4 py-2 rounded-full border mb-8"
      style={`color: ${accent}; border-color: ${accent}33; background: ${accent}11;`}>
      <span class="w-1.5 h-1.5 rounded-full animate-pulse" style={`background: ${accent};`}></span>
      Live in production
    </span>

    <!-- Headline -->
    <h1 class="text-5xl md:text-7xl lg:text-[6.5rem] font-medium tracking-tighter leading-[1.05] text-white mb-6">
      FormPush.io
    </h1>

    <!-- Sub-headline -->
    <p class="text-lg md:text-xl text-neutral-400 max-w-2xl mx-auto tracking-normal leading-relaxed mb-10">
      Turn any Notion database into a powerful, elegant web form. Every submission lands directly in the user's Notion — no middleware, no friction.
    </p>

    <div class="flex flex-wrap items-center justify-center gap-4">
      <a
        href="https://formpush.io"
        target="_blank"
        rel="noopener"
        class="px-8 py-3.5 rounded-full bg-primary hover:bg-primary-hover text-white font-semibold text-sm transition-colors duration-300"
      >
        Visit FormPush.io →
      </a>
      <a
        href="/#process"
        class="px-8 py-3.5 rounded-full bg-white/5 border border-white/10 text-white font-medium text-sm hover:bg-white/10 hover:border-white/20 transition-all duration-300"
      >
        See the 10-phase process
      </a>
    </div>
  </section>

  <main class="w-full max-w-7xl mx-auto px-6 pb-32">

    <!-- ── Metrics band ─────────────────────────────────────────────── -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-24">
      {metrics.map((m) => (
        <div class="rounded-[24px] border border-[#1A1A1A] bg-[#050505] p-8 flex flex-col gap-2">
          <span class="text-4xl md:text-5xl font-medium tracking-tighter text-white">{m.value}</span>
          <span class="text-sm font-semibold text-neutral-300">{m.label}</span>
          <span class="text-xs text-neutral-500">{m.note}</span>
        </div>
      ))}
    </div>

    <!-- ── Screens gallery ──────────────────────────────────────────── -->
    <div class="mb-24">
      <p class="text-xs text-neutral-600 uppercase tracking-widest font-mono mb-6">Inside the product</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {screens.map((s) => (
          <figure class={`group rounded-[24px] border border-[#1A1A1A] bg-[#050505] overflow-hidden transition-all duration-500 hover:border-[#2A2A2A] ${s.wide ? 'md:col-span-2' : ''}`}>
            <div class="overflow-hidden border-b border-[#1A1A1A]">
              <img
                src={s.src}
                alt={s.alt}
                loading="lazy"
                class="w-full h-auto transition-transform duration-700 group-hover:scale-[1.02]"
              />
            </div>
            <figcaption class="p-5 text-sm text-neutral-500">{s.caption}</figcaption>
          </figure>
        ))}
      </div>
    </div>

    <!-- ── What we built ────────────────────────────────────────────── -->
    <div class="mb-24">
      <p class="text-xs text-neutral-600 uppercase tracking-widest font-mono mb-6">What we built</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {capabilities.map((c) => (
          <div class="rounded-[24px] border border-[#1A1A1A] bg-[#050505] p-8">
            <h3 class="text-lg font-semibold text-white mb-3">{c.title}</h3>
            <p class="text-sm text-neutral-400 leading-relaxed">{c.desc}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- ── Process proof ────────────────────────────────────────────── -->
    <div class="rounded-[24px] border border-[#1A1A1A] bg-[#050505] p-10 md:p-14 mb-24 relative overflow-hidden">
      <div class="absolute bottom-0 right-0 w-[400px] h-[300px] rounded-full blur-[120px] opacity-10 pointer-events-none" style={`background: ${accent};`}></div>
      <div class="relative z-10 max-w-3xl">
        <p class="text-xs text-neutral-600 uppercase tracking-widest font-mono mb-6">Proof of process</p>
        <h2 class="text-3xl md:text-5xl font-medium tracking-tighter text-white leading-[1.1] mb-6">
          From phase 00 to 09.<br />Idea to recurring revenue.
        </h2>
        <p class="text-neutral-400 leading-relaxed mb-8">
          FormPush.io went through every one of our ten phases — Discovery &amp; Validation, Brand, Product Design, Architecture, Development, Infrastructure &amp; DevOps, Testing &amp; QA, Go-to-Market, Launch, and Support &amp; Continuous Operation. The result is a live SaaS with paying customers and growing monthly recurring revenue — the clearest evidence of how efficiently the full lifecycle works when one team owns all of it.
        </p>
        <a href="/#process" class="inline-flex items-center gap-2 text-sm font-medium text-white hover:text-primary transition-colors">
          Explore the 10-phase process
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
        </a>
      </div>
    </div>

    <!-- ── Acquisition offer ────────────────────────────────────────── -->
    <div class="rounded-[24px] border p-10 md:p-14 mb-24 relative overflow-hidden" style={`border-color: ${accent}33; background: linear-gradient(180deg, ${accent}0A, #050505);`}>
      <div class="relative z-10 grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
        <div>
          <p class="text-xs uppercase tracking-widest font-mono mb-6" style={`color: ${accent};`}>Acquisition opportunity</p>
          <h2 class="text-3xl md:text-5xl font-medium tracking-tighter text-white leading-[1.1] mb-6">
            This asset is available.
          </h2>
          <p class="text-neutral-400 leading-relaxed">
            FormPush.io can be acquired as a fully operational, revenue-generating SaaS. The current valuation stands at <span class="text-white font-medium">$21,000</span> — and it is pegged to recurring revenue: every new subscriber automatically increases the asset's value. The sooner the conversation starts, the better the price.
          </p>
        </div>
        <div class="flex flex-col gap-4">
          <div class="rounded-2xl border border-[#1A1A1A] bg-black/40 p-6 flex items-baseline justify-between">
            <span class="text-sm text-neutral-400">Valuation to date</span>
            <span class="text-3xl font-medium tracking-tighter text-white">$21,000</span>
          </div>
          <div class="rounded-2xl border border-[#1A1A1A] bg-black/40 p-6 flex items-baseline justify-between">
            <span class="text-sm text-neutral-400">Monthly recurring revenue</span>
            <span class="text-3xl font-medium tracking-tighter text-white">$240<span class="text-base text-neutral-500">/mo</span></span>
          </div>
          <a
            href="/contact"
            class="px-8 py-4 rounded-full text-center text-white font-semibold text-sm transition-colors duration-300"
            style={`background: ${accent};`}
          >
            Talk to us about this asset
          </a>
        </div>
      </div>
    </div>

    <!-- ── Secondary CTA ─────────────────────────────────────────────── -->
    <div class="flex flex-col items-center gap-6 text-center">
      <p class="text-neutral-500 text-sm tracking-wide uppercase font-mono">Want a SaaS like this built for you?</p>
      <div class="flex flex-wrap items-center justify-center gap-4">
        <a
          href="/partnership"
          class="px-8 py-3.5 rounded-full bg-primary hover:bg-primary-hover text-white font-semibold text-sm transition-colors duration-300"
        >
          Apply for Partnership
        </a>
        <a
          href="/company"
          class="px-8 py-3.5 rounded-full bg-white/5 border border-white/10 text-white font-medium text-sm hover:bg-white/10 hover:border-white/20 transition-all duration-300"
        >
          About the Studio →
        </a>
      </div>
    </div>

  </main>

  <Footer />

</Layout>
