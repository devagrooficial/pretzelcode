---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

// Pipeline nodes (00 → 09) laid out along the serpentine SVG path.
// `delay` syncs each node's pulse with the moment the worm head passes it (12s cycle).
const pipeline = [
  { num: '00', title: 'Discovery',    x: 100, y: 70,  delay: 0     },
  { num: '01', title: 'Brand',        x: 367, y: 70,  delay: 1.2   },
  { num: '02', title: 'UX/UI',        x: 633, y: 70,  delay: 2.4   },
  { num: '03', title: 'Architecture', x: 900, y: 70,  delay: 3.6   },
  { num: '04', title: 'Development',  x: 700, y: 250, delay: 5.78  },
  { num: '05', title: 'DevOps',       x: 450, y: 250, delay: 6.9   },
  { num: '06', title: 'QA',           x: 200, y: 250, delay: 8.03  },
  { num: '07', title: 'Go-to-Market', x: 330, y: 430, delay: 9.88  },
  { num: '08', title: 'Launch',       x: 560, y: 430, delay: 10.92 },
  { num: '09', title: 'Operate',      x: 800, y: 430, delay: 11.95 },
];
---

<Layout>
  <Navbar />
  
  <main class="flex-1 w-full max-w-7xl mx-auto px-6 py-12 md:py-24 flex flex-col gap-16">
    <header class="w-full flex flex-col items-center justify-center text-center pt-16 md:pt-24 pb-12 overflow-visible">
      <span class="text-primary font-semibold tracking-widest uppercase text-sm mb-4">Our Approach</span>
      <h1 class="text-5xl md:text-7xl lg:text-[8rem] font-medium tracking-tighter leading-[1.05] text-white">
        Builders first. <br class="hidden md:block"/>Agency second.
      </h1>
      <p class="text-lg md:text-xl text-neutral-400 max-w-2xl mx-auto tracking-normal leading-relaxed mt-6">
        We are engineers, founders, and operators. Pretzel Code was built to engineer the kind of software we would invest in ourselves. Zero bureaucracy, 100% focus on shipping code.
      </p>
    </header>

    <!-- The Manifesto -->
    <article class="w-full max-w-2xl mx-auto px-4 mt-8 md:mt-16 mb-24 md:mb-32">
      <div class="prose prose-invert prose-lg md:prose-xl font-sans text-gray-300 leading-relaxed font-light">
        <p class="mb-8">
          Pretzel Code was forged in the trenches of heavy-duty software engineering. We don't just build glossy landing pages; we architect the operational backbones that keep companies moving.
        </p>
        <p class="mb-8">
          Our deepest expertise lies in untangling absolute chaos. We have spent years engineering high-stakes Field Service Management platforms—systems that handle advanced routing algorithms, coordinate fleets of technicians on the streets, and synchronize offline field data with legacy ERPs under punishing constraints.
        </p>
        <p class="mb-12">
          The logic is simple: <strong class="text-white font-medium">If we can solve the unpredictable, physical-world problems of field operations with code, we can solve any digital SaaS challenge you throw at us.</strong> We bring that exact same rigorous, fault-tolerant engineering mindset to every product we incubate or build for our partners.
        </p>
        
        <div class="border-t border-[#1A1A1A] pt-8 mt-12 flex flex-col items-start">
          <p class="text-white font-medium text-lg m-0">Luis Nathan</p>
          <p class="text-gray-500 text-sm tracking-wide uppercase font-mono m-0 mt-1">Founder & Lead Engineer</p>
        </div>
      </div>
    </article>

    <!-- The SaaS Factory -->
    <section class="w-full relative mt-12 md:mt-16 rounded-[32px] overflow-hidden border border-[#1A1A1A] bg-[#050505]">
      <div class="absolute inset-0 noise-bg opacity-[0.03]"></div>
      <div class="p-10 md:p-16 lg:p-24 flex flex-col lg:flex-row gap-12 items-center relative z-10 w-full">
        <div class="flex-1 w-full">
          <h2 class="text-4xl md:text-5xl lg:text-5xl xl:text-6xl font-bold text-white mb-8 tracking-tight leading-tight">We eat our own dog food.</h2>
          <p class="text-gray-400 text-lg md:text-xl font-light leading-relaxed mb-6">
            We don't just build for clients. We continuously conceptualize, build, and operate our own proprietary software products.
          </p>
          <p class="text-gray-400 text-lg md:text-xl font-light leading-relaxed">
            This internal <span class="text-white font-medium">SaaS Factory</span> forces us to stay sharp, deal with real-world infrastructure scaling, and constantly refine our custom Python, Node.js, and React Native toolchains. When we build your product, we use the exact same elite architecture we use to build ours.
          </p>
        </div>
        <div class="w-full lg:w-2/5 flex justify-center items-center">
          <div class="relative w-full aspect-square max-w-sm border border-[#171717] bg-[#090909] rounded-[24px] flex items-center justify-center overflow-hidden shadow-[0_0_80px_rgba(255,255,255,0.02)]">
            <div class="absolute inset-0 flex items-center justify-center opacity-10">
               <svg class="w-full h-full text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg>
            </div>
            <span class="text-[#333] font-mono text-sm tracking-widest relative z-10 flex items-center gap-3">
              <span class="w-2 h-2 rounded-full bg-emerald-500 shadow-[0_0_10px_#10B981] animate-pulse"></span>
              INTERNAL_FACTORY
            </span>
          </div>
        </div>
      </div>
    </section>

    <!-- The Operating System -->
    <section class="w-full mt-16 md:mt-32">
      <div class="flex flex-col items-center text-center mb-16">
        <span class="text-xs md:text-sm uppercase tracking-[0.3em] font-bold text-[#666] mb-4 font-mono">Operations</span>
        <h2 class="text-3xl md:text-5xl font-bold text-white tracking-tight">The Operating System.</h2>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-12 gap-6 w-full">
        
        <!-- Box 1 (6 col): Nearshore & Async -->
        <div class="md:col-span-6 bg-[#050505] border border-[#1A1A1A] rounded-[24px] p-8 md:p-10 relative overflow-hidden group">
          <div class="absolute inset-0 noise-bg opacity-[0.03]"></div>
          <div class="relative z-10 flex flex-col h-full">
            <div class="mb-10 w-full flex items-center justify-between border-b border-[#1A1A1A] pb-4">
               <span class="text-primary font-mono text-xs uppercase tracking-widest">Nearshore & Async</span>
               <div class="flex items-center gap-2 px-3 py-1 bg-[#111] border border-[#222] rounded-full">
                  <span class="w-1.5 h-1.5 bg-emerald-500 rounded-full animate-pulse shadow-[0_0_5px_#10B981]"></span>
                  <span class="text-[10px] text-gray-400 font-mono">EST/PST SYNC</span>
               </div>
            </div>
            <h3 class="text-2xl font-bold text-white mb-6 leading-snug">Same Timezone,<br/><span class="text-gray-500">Silicon Valley Standard.</span></h3>
            <p class="text-gray-400 font-light leading-relaxed mt-auto">
              Headquartered in Delaware, we operate on US time for crucial syncs, while our execution is 80% asynchronous. Fewer Zoom calls, more code pushed.
            </p>
          </div>
        </div>
        
        <!-- Box 2 (6 col): No Middlemen -->
        <div class="md:col-span-6 bg-[#050505] border border-[#1A1A1A] rounded-[24px] p-8 md:p-10 relative overflow-hidden group">
          <div class="absolute inset-0 noise-bg opacity-[0.03]"></div>
          <div class="relative z-10 flex flex-col h-full">
            <div class="mb-10 w-full flex items-center justify-between border-b border-[#1A1A1A] pb-4">
               <span class="text-primary font-mono text-xs uppercase tracking-widest">No Middlemen</span>
               <div class="flex items-center justify-center">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" class="text-[#555]" stroke="currentColor" stroke-width="1.5"><path d="M18 6L6 18M6 6l12 12"/></svg>
               </div>
            </div>
            <h3 class="text-2xl font-bold text-white mb-6 leading-snug">Direct to<br/><span class="text-gray-500">Engineers.</span></h3>
            <p class="text-gray-400 font-light leading-relaxed mt-auto">
              You don't talk to account managers who can't read code. You talk directly to the full-stack architects building your product.
            </p>
          </div>
        </div>

        <!-- Box 3 (12 col): The Anti-Bloat Philosophy -->
        <div class="col-span-1 md:col-span-12 bg-[#050505] border border-[#1A1A1A] rounded-[24px] p-8 md:p-12 relative overflow-hidden group min-h-[300px] flex flex-col md:flex-row gap-12 items-center">
          <div class="absolute inset-0 noise-bg opacity-[0.03]"></div>
          
          <div class="flex-1 relative z-10">
            <div class="text-primary font-mono text-xs uppercase tracking-widest mb-6">Architecture</div>
            <h3 class="text-3xl md:text-4xl font-bold text-white mb-6 leading-snug">The Anti-Bloat<br/><span class="text-gray-500">Philosophy.</span></h3>
            <p class="text-gray-400 font-light leading-relaxed max-w-2xl">
              We hate slow software. Our philosophy is lean architecture and modern infrastructure. We automate heavy processes using custom Python or Node.js microservices, chosen based on each project's complexity, focusing human intelligence entirely on your unique business logic.
            </p>
          </div>

          <!-- CLI Animation Mock -->
          <div class="w-full md:w-1/3 h-48 bg-[#000] border border-[#222] rounded-[16px] p-6 relative z-10 font-mono text-xs md:text-sm text-[#4ade80] flex flex-col justify-end overflow-hidden shadow-[0_0_30px_rgba(0,0,0,0.5)] group-hover:border-[#333] transition-colors duration-500">
            <div class="w-full flex items-center gap-2 absolute top-4 left-4">
              <div class="w-2.5 h-2.5 rounded-full bg-[#ff5f56]"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-[#ffbd2e]"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-[#27c93f]"></div>
            </div>
            <div class="mt-8 flex flex-col gap-2 opacity-80">
              <div class="flex gap-2"><span>></span><span class="text-gray-500 line-through decoration-red-500">rm -rf legacy_bloat/</span></div>
              <div class="flex gap-2"><span>></span><span class="text-gray-500 line-through decoration-red-500">rm -rf boilerplate_code/</span></div>
              <div class="flex gap-2 animate-pulse mt-2"><span>></span><span class="text-white relative">deploy_microservices.py <span class="absolute -right-2 top-0 bottom-0 w-1.5 bg-white animate-pulse"></span></span></div>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- The Pipeline -->
    <section id="pipeline" class="w-full relative mt-24 md:mt-32 rounded-[32px] overflow-hidden border border-[#1A1A1A] bg-[#050505] scroll-mt-24">
      <div class="absolute inset-0 noise-bg opacity-[0.03] pointer-events-none"></div>

      <div class="relative z-10 p-8 md:p-16">

        <div class="flex flex-col items-center text-center mb-12 md:mb-16">
          <span class="text-xs md:text-sm uppercase tracking-[0.3em] font-bold text-[#666] mb-4 font-mono">The Method</span>
          <h2 class="text-3xl md:text-5xl font-bold text-white tracking-tight mb-4">From 00 to 09. Every time.</h2>
          <p class="text-gray-400 font-light leading-relaxed max-w-2xl">
            Every product we ship travels the same disciplined pipeline — no skipped phases, no handoffs, one team owning the whole run.
          </p>
        </div>

        <!-- Serpentine pipeline animation -->
        <svg viewBox="0 0 1000 500" class="w-full h-auto select-none" role="img" aria-label="The ten-phase pipeline, from Discovery to Continuous Operation">
          <defs>
            <linearGradient id="worm-grad" x1="0" y1="0" x2="1" y2="0">
              <stop offset="0" stop-color="#AC481A" stop-opacity="0" />
              <stop offset="0.5" stop-color="#AC481A" />
              <stop offset="1" stop-color="#FF8A4C" />
            </linearGradient>
          </defs>

          <!-- Base track -->
          <path
            id="pipe-path"
            d="M 100 70 L 900 70 C 985 70 985 250 900 250 L 200 250 C 115 250 115 430 200 430 L 800 430"
            fill="none" stroke="#1E1E1E" stroke-width="2" pathLength="1000"
          />

          <!-- Traveling worm -->
          <path
            class="pipe-worm"
            d="M 100 70 L 900 70 C 985 70 985 250 900 250 L 200 250 C 115 250 115 430 200 430 L 800 430"
            fill="none" stroke="url(#worm-grad)" stroke-width="3.5" stroke-linecap="round" pathLength="1000"
          />

          <!-- Worm head -->
          <g class="pipe-head">
            <circle r="10" fill="#AC481A" opacity="0.35" />
            <circle r="4" fill="#FFFFFF" />
            <animateMotion dur="12s" repeatCount="indefinite" rotate="0">
              <mpath href="#pipe-path" />
            </animateMotion>
          </g>

          <!-- Phase nodes -->
          {pipeline.map((p) => (
            <g transform={`translate(${p.x}, ${p.y})`}>
              <circle class="node-ring" r="14" fill="none" stroke="#AC481A" stroke-width="1.5" style={`animation-delay: ${p.delay}s;`} />
              <circle r="14" fill="#0A0A0A" stroke="#2A2A2A" stroke-width="1.5" />
              <text class="node-num" y="3.5" text-anchor="middle">{p.num}</text>
              <text class="node-title" y="38" text-anchor="middle">{p.title}</text>
            </g>
          ))}
        </svg>

        <!-- Pipeline output: FormPush.io -->
        <div class="mt-14 md:mt-20 flex flex-col items-center">
          <p class="text-neutral-500 text-xs md:text-sm tracking-wide uppercase font-mono mb-6">Latest asset shipped through this pipeline</p>
          <a href="/portfolio" class="group block w-full max-w-3xl rounded-[24px] border border-[#222] bg-black overflow-hidden transition-all duration-500 hover:border-[#333] hover:shadow-[0_32px_64px_rgba(0,0,0,0.5)]">
            <div class="flex items-center gap-2 px-5 py-3.5 border-b border-[#1A1A1A] bg-[#050505]">
              <div class="w-2.5 h-2.5 rounded-full bg-[#ff5f56]"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-[#ffbd2e]"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-[#27c93f]"></div>
              <span class="ml-3 text-[11px] font-mono text-neutral-500 tracking-wide">formpush.io</span>
              <span class="ml-auto text-[11px] font-mono text-neutral-600 tracking-wide group-hover:text-neutral-400 transition-colors">View case study →</span>
            </div>
            <img
              src="/images/lp.png"
              alt="FormPush.io — live SaaS shipped through the ten-phase pipeline"
              loading="lazy"
              class="w-full h-auto transition-transform duration-700 group-hover:scale-[1.01]"
            />
          </a>
        </div>

      </div>
    </section>

    <!-- The CTA -->
    <section class="w-full mt-24 md:mt-32 mb-24 flex flex-col items-center justify-center text-center relative">
      <h2 class="text-4xl md:text-5xl lg:text-7xl font-bold text-white mb-6 tracking-tighter relative z-10">Let's build your SaaS together.</h2>
      <p class="text-gray-400 text-lg md:text-xl font-light leading-relaxed max-w-2xl mb-12 relative z-10">
        New builds run through one model: The Equity Partnership. You cover 30% of the build, we invest 70%, and you keep 60% of the upside — by application only.
      </p>
      <a href="/partnership" class="group relative z-10 px-8 py-5 bg-primary text-white font-bold rounded-full hover:bg-primary-hover transition-colors shadow-[0_0_30px_var(--color-primary-glow)] flex items-center justify-center gap-3 text-lg">
        Apply for Partnership
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="transform group-hover:translate-x-1 transition-transform"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
      </a>
    </section>
  </main>
  
  <Footer />
</Layout>

<style>
  /* Worm: a 70-unit dash (of a 1000-unit normalized path) travels 00 → 09 on a 12s loop.
     Offset runs 1070 → 70 so the head of the dash leads and lands on each node
     in sync with the pulse delays defined in the frontmatter. */
  .pipe-worm {
    stroke-dasharray: 70 930;
    stroke-dashoffset: 1070;
    animation: worm-travel 12s linear infinite;
  }

  @keyframes worm-travel {
    from { stroke-dashoffset: 1070; }
    to   { stroke-dashoffset: 70; }
  }

  .node-ring {
    transform-box: fill-box;
    transform-origin: center;
    transform: scale(1);
    opacity: 0;
    animation: node-pulse 12s linear infinite;
  }

  @keyframes node-pulse {
    0%   { transform: scale(1);   opacity: 0; }
    1%   { transform: scale(1);   opacity: 0.7; }
    8%   { transform: scale(2.4); opacity: 0; }
    100% { transform: scale(2.4); opacity: 0; }
  }

  .node-num {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 11px;
    font-weight: 600;
    fill: #999;
    letter-spacing: 0.05em;
  }

  .node-title {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 13px;
    fill: #666;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  /* On small screens the SVG scales down — keep only the numbers legible. */
  @media (max-width: 640px) {
    .node-title { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .pipe-worm, .node-ring { animation: none; }
    .pipe-worm { stroke-dashoffset: 70; }
    .pipe-head { display: none; }
  }
</style>
