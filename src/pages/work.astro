---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <Navbar />
  
  <!-- Proof of Work Hero -->
  <section class="relative w-full h-[100vh] min-h-[700px] bg-[#000000] flex flex-col items-center justify-center border-b border-[#1A1A1A]">
    <div class="relative z-10 text-center px-6 max-w-5xl mx-auto flex flex-col items-center">
      <div class="text-primary font-semibold tracking-widest uppercase text-sm mb-4">Proof of Work.</div>
      <h1 class="text-5xl md:text-7xl lg:text-[8rem] font-medium tracking-tighter leading-[1.05] text-white">
        Built for the real world.
      </h1>
      <p class="text-lg md:text-xl text-neutral-400 max-w-2xl mx-auto tracking-normal leading-relaxed mt-6">
        We don't just design pretty interfaces. We architect digital products that process data, scale operations, and generate revenue. Explore our recent teardowns.
      </p>
    </div>

    <!-- Motion Vertical Line Tracker -->
    <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[1px] h-32 bg-[#111] overflow-hidden flex items-start">
        <div class="w-full h-full bg-[#333] origin-top animate-[growDown_2s_ease-in-out_infinite]"></div>
    </div>
  </section>

  <style>
    @keyframes growDown {
      0% { transform: scaleY(0); }
      70% { transform: scaleY(1); opacity: 1; }
      100% { transform: scaleY(1); opacity: 0; }
    }
  </style>

  <main class="flex-1 w-full max-w-7xl mx-auto px-6 py-24 md:py-32 flex flex-col gap-16">

    <div class="flex flex-col gap-32 w-full">
      
      <!-- NexusFlow Sticky Scroll Case -->
      <section class="flex flex-col lg:flex-row gap-16 lg:gap-24 relative items-start w-full">
        
        <!-- Left: Sticky Sidebar -->
        <div class="w-full lg:w-1/3 lg:sticky lg:top-32 flex flex-col z-10">
          <span class="text-xs uppercase tracking-widest text-blue-500 font-bold mb-4 font-mono">B2B SaaS</span>
          <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-8 tracking-tight">NexusFlow</h2>
          
          <div class="h-[1px] w-full bg-[#1A1A1A] mb-8"></div>
          
          <div class="mb-8">
             <h4 class="text-white font-bold mb-3 uppercase tracking-wider text-sm">The Challenge</h4>
             <p class="text-gray-400 font-light leading-relaxed">
               Build a fast and resilient search and monitoring engine. Mapping complex workflows into seamless operations capable of handling high-concurrency environments natively.
             </p>
          </div>

          <div class="mb-8">
             <h4 class="text-white font-bold mb-3 uppercase tracking-wider text-sm">The Stack</h4>
             <div class="flex gap-3 items-center flex-wrap">
                <span class="px-4 py-1.5 bg-[#111111] border border-[#222] rounded-full text-xs text-white font-mono shadow-sm flex items-center gap-2">
                  <span class="w-1.5 h-1.5 rounded-full bg-blue-500"></span> Python
                </span>
                <span class="px-4 py-1.5 bg-[#111111] border border-[#222] rounded-full text-xs text-white font-mono shadow-sm flex items-center gap-2">
                  <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span> Supabase
                </span>
             </div>
          </div>

          <div>
             <h4 class="text-white font-bold mb-3 uppercase tracking-wider text-sm">The Outcome</h4>
             <p class="text-gray-400 font-light leading-relaxed text-emerald-400/90">
               Scalable architecture delivering real-time data streaming with minimal latency. Zero dropped payloads under massive ingestion.
             </p>
          </div>
        </div>

        <!-- Right: Scrolling Bento Content -->
        <div class="w-full lg:w-2/3 flex flex-col gap-8">
          
          <!-- Box 1: Mockup Placeholder -->
          <div class="w-full rounded-[32px] border border-[#1A1A1A] bg-[#050505] min-h-[500px] p-8 md:p-12 flex flex-col relative overflow-hidden group">
            <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-blue-900/10 via-transparent to-transparent pointer-events-none opacity-50 group-hover:opacity-100 transition-opacity duration-700"></div>
            
            <h3 class="text-xl font-bold text-white mb-6 relative z-10 opacity-30">01 / The Interface</h3>
            
            <div class="flex-1 w-full flex items-center justify-center relative z-10 pt-12">
               <!-- Macbook 3D Context -->
               <div class="w-[90%] max-w-[600px] aspect-[16/10] bg-[#0A0A0A] border-t-8 border-x-8 border-[#1A1A1A] rounded-t-3xl shadow-2xl relative flex flex-col overflow-hidden group-hover:-translate-y-4 transition-transform duration-700">
                  <div class="w-full h-5 bg-[#111] flex items-center px-4 gap-2 border-b border-[#222]">
                    <div class="w-2.5 h-2.5 rounded-full bg-red-500/50"></div>
                    <div class="w-2.5 h-2.5 rounded-full bg-yellow-500/50"></div>
                    <div class="w-2.5 h-2.5 rounded-full bg-emerald-500/50"></div>
                  </div>
                  <div class="flex-1 flex flex-col items-center justify-center bg-[#050505] p-8 gap-4">
                    <span class="text-[#333] font-mono text-sm tracking-widest uppercase">Desktop Client</span>
                    <div class="w-full h-full border border-[#1A1A1A] rounded-xl flex items-center justify-center bg-[#020202]">
                       <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8 text-[#333]"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="3" y1="9" x2="21" y2="9"></line><line x1="9" y1="21" x2="9" y2="9"></line></svg>
                    </div>
                  </div>
               </div>
               
               <!-- Base of Macbook (Floating) -->
               <div class="absolute top-[50%] mt-[calc(18vw+30px)] md:mt-[220px] lg:mt-[180px] xl:mt-[220px] w-[100%] max-w-[700px] h-4 bg-gradient-to-b from-[#222] to-[#111] rounded-b-2xl shadow-2xl flex justify-center group-hover:-translate-y-4 transition-transform duration-700 z-20">
                 <div class="w-1/5 h-1.5 bg-[#0A0A0A] rounded-b-md"></div>
               </div>
            </div>
          </div>

          <!-- Box 2: Feature Placeholder -->
          <div class="w-full rounded-[32px] border border-[#1A1A1A] bg-[#050505] min-h-[500px] p-8 md:p-12 flex flex-col relative overflow-hidden group">
            <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom,_var(--tw-gradient-stops))] from-emerald-900/10 via-transparent to-transparent pointer-events-none opacity-50 group-hover:opacity-100 transition-opacity duration-700"></div>

            <h3 class="text-xl font-bold text-white mb-6 relative z-10 opacity-30">02 / Real-time Engine</h3>

            <div class="flex-1 w-full flex flex-col items-center justify-center relative z-10 gap-8">
              <!-- Supabase Data Flow DB Mock -->
              <div class="w-full max-w-[450px] aspect-[2/1] flex justify-between items-center px-8 border border-[#1A1A1A] bg-[#0A0A0A] rounded-[24px] p-6 shadow-2xl relative overflow-hidden">
                 
                 <!-- Flow animation paths -->
                 <style>
                    .dash-path {
                      stroke-dasharray: 4 8;
                      animation: slide 2s linear infinite;
                    }
                    @keyframes slide {
                      to { stroke-dashoffset: -24; }
                    }
                 </style>
                 <svg class="absolute inset-0 w-full h-full pointer-events-none" viewBox="0 0 100 50" preserveAspectRatio="none">
                    <line x1="0" y1="25" x2="100" y2="25" stroke="#222" stroke-width="0.5"/>
                    <line x1="0" y1="25" x2="100" y2="25" stroke="#10B981" stroke-width="0.5" class="dash-path opacity-0 group-hover:opacity-100 transition-opacity duration-500"/>
                 </svg>
                 
                 <!-- Node 1 -->
                 <div class="w-16 h-16 rounded-full bg-[#111] border border-[#333] flex items-center justify-center relative z-10 group-hover:border-blue-500/50 transition-colors duration-500">
                   <span class="w-3 h-3 rounded-full bg-blue-500 animate-pulse"></span>
                 </div>
                 
                 <!-- Middle DB -->
                 <div class="w-24 h-28 rounded-2xl bg-[#050505] border border-emerald-500/30 flex flex-col items-center justify-center relative z-10 gap-2 shadow-[0_0_30px_rgba(16,185,129,0.1)] group-hover:shadow-[0_0_40px_rgba(16,185,129,0.2)] group-hover:border-emerald-500/60 transition-all duration-500">
                   <div class="w-12 h-2.5 rounded-full border border-emerald-500/50"></div>
                   <div class="w-12 h-2.5 rounded-full border border-emerald-500/50"></div>
                   <div class="w-12 h-2.5 rounded-full border border-emerald-500 bg-emerald-500/20"></div>
                 </div>
                 
                 <!-- Node 2 -->
                 <div class="w-16 h-16 rounded-full bg-[#111] border border-[#333] flex items-center justify-center relative z-10 group-hover:border-rose-500/50 transition-colors duration-500">
                   <span class="w-3 h-3 rounded-full bg-rose-500 animate-pulse" style="animation-delay: 500ms"></span>
                 </div>
              </div>
              
              <div class="text-center mt-2 opacity-0 -translate-y-4 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-500">
                <span class="px-4 py-2 bg-emerald-500/10 border border-emerald-500/30 rounded-full text-xs text-emerald-400 font-mono tracking-widest">SUPABASE_REALTIME_ACTIVE</span>
              </div>
            </div>
          </div>
          
        </div>
      </section>

      <!-- VaultMetrics Sticky Scroll Case -->
      <section class="flex flex-col lg:flex-row gap-16 lg:gap-24 relative items-start w-full">
        
        <!-- Left: Sticky Sidebar -->
        <div class="w-full lg:w-1/3 lg:sticky lg:top-32 flex flex-col z-10">
          <span class="text-xs uppercase tracking-widest text-[#a855f7] font-bold mb-4 font-mono">Workflow Automation</span>
          <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-8 tracking-tight">VaultMetrics</h2>
          
          <div class="h-[1px] w-full bg-[#1A1A1A] mb-8"></div>
          
          <div class="mb-8">
             <h4 class="text-white font-bold mb-3 uppercase tracking-wider text-sm">The Challenge</h4>
             <p class="text-gray-400 font-light leading-relaxed">
               Create an autonomous lead acquisition engine. The objective was to replace a fragmented 5-tool sequence with a centralized, data-driven automation pipeline.
             </p>
          </div>

          <div class="mb-8">
             <h4 class="text-white font-bold mb-3 uppercase tracking-wider text-sm">The Stack</h4>
             <div class="flex gap-3 items-center flex-wrap">
                <span class="px-4 py-1.5 bg-[#111111] border border-[#222] rounded-full text-xs text-white font-mono shadow-sm flex items-center gap-2">
                  <span class="w-1.5 h-1.5 rounded-full bg-[#a855f7]"></span> Event-Driven Architecture
                </span>
                <span class="px-4 py-1.5 bg-[#111111] border border-[#222] rounded-full text-xs text-white font-mono shadow-sm flex items-center gap-2">
                  <span class="w-1.5 h-1.5 rounded-full bg-[#3b82f6]"></span> Python Microservices
                </span>
             </div>
          </div>

          <div>
             <h4 class="text-white font-bold mb-3 uppercase tracking-wider text-sm">The Outcome</h4>
             <p class="text-gray-400 font-light leading-relaxed text-[#a855f7]">
               End-to-end automation, reducing manual work and injecting qualified leads directly into the CRM in under 200ms per trigger.
             </p>
          </div>
        </div>

        <!-- Right: Scrolling Bento Content -->
        <div class="w-full lg:w-2/3 flex flex-col gap-8">
          
          <!-- Box 1: Mockup Placeholder -->
          <div class="w-full rounded-[32px] border border-[#1A1A1A] bg-[#050505] min-h-[500px] p-8 md:p-12 flex flex-col relative overflow-hidden group">
            <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-purple-900/10 via-transparent to-transparent pointer-events-none opacity-50 group-hover:opacity-100 transition-opacity duration-700"></div>
            
            <h3 class="text-xl font-bold text-white mb-6 relative z-10 opacity-30">01 / The Dashboard</h3>
            
            <div class="flex-1 w-full flex items-center justify-center relative z-10 pt-12">
               <!-- Lead Gen Chart Context -->
               <div class="w-[90%] max-w-[600px] aspect-[16/10] bg-[#0A0A0A] border border-[#1A1A1A] rounded-2xl shadow-2xl relative flex flex-col overflow-hidden group-hover:-translate-y-4 transition-transform duration-700 p-8 gap-6">
                  
                  <div class="flex items-center justify-between">
                     <span class="text-[#555] font-mono text-sm tracking-widest uppercase">Lead Acquisition</span>
                     <div class="px-3 py-1 bg-purple-500/10 border border-purple-500/20 rounded-full text-purple-400 text-xs font-mono">+34.2%</div>
                  </div>

                  <div class="flex-1 w-full flex gap-4 mt-auto items-end">
                     <div class="w-1/6 bg-[#111] rounded-t-sm h-[30%] group-hover:bg-[#222] transition-colors duration-300"></div>
                     <div class="w-1/6 bg-[#111] rounded-t-sm h-[45%] group-hover:bg-[#222] transition-colors duration-300"></div>
                     <div class="w-1/6 bg-[#111] rounded-t-sm h-[20%] group-hover:bg-[#222] transition-colors duration-300"></div>
                     <div class="w-1/6 bg-[#1A1A1A] rounded-t-sm h-[60%] group-hover:bg-[#2A2A2A] transition-colors duration-300"></div>
                     <div class="w-1/6 bg-purple-500/20 border-t border-purple-500/50 rounded-t-sm h-[85%] relative">
                        <div class="absolute -top-3 left-1/2 -translate-x-1/2 w-2 h-2 rounded-full bg-purple-500 shadow-[0_0_10px_rgba(168,85,247,0.8)]"></div>
                     </div>
                     <div class="w-1/6 bg-[#111] rounded-t-sm h-[65%] group-hover:bg-[#222] transition-colors duration-300"></div>
                  </div>
               </div>
               
            </div>
          </div>

          <!-- Box 2: Node Engine Placeholder -->
          <div class="w-full rounded-[32px] border border-[#1A1A1A] bg-[#050505] min-h-[500px] p-8 md:p-12 flex flex-col relative overflow-hidden group">
            <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom,_var(--tw-gradient-stops))] from-fuchsia-900/10 via-transparent to-transparent pointer-events-none opacity-50 group-hover:opacity-100 transition-opacity duration-700"></div>

            <h3 class="text-xl font-bold text-white mb-6 relative z-10 opacity-30">02 / The Automation Node</h3>

            <div class="flex-1 w-full flex flex-col items-center justify-center relative z-10 gap-8">
              <!-- Node-based Microservices Layout Mock -->
              <div class="w-full max-w-[500px] aspect-[2/1] flex relative p-6">
                 
                 <!-- SVG Lines (Neon Glowing on Hover) -->
                 <svg class="absolute inset-0 w-full h-full pointer-events-none z-0" viewBox="0 0 100 50" preserveAspectRatio="none">
                    <!-- Base dark lines -->
                    <path d="M 20 25 C 40 25, 40 15, 50 15" fill="none" stroke="#222" stroke-width="0.5" />
                    <path d="M 20 25 C 40 25, 40 35, 50 35" fill="none" stroke="#222" stroke-width="0.5" />
                    <path d="M 60 15 C 70 15, 75 25, 80 25" fill="none" stroke="#222" stroke-width="0.5" />
                    <path d="M 60 35 C 70 35, 75 25, 80 25" fill="none" stroke="#222" stroke-width="0.5" />
                    
                    <!-- Neon hover lines -->
                    <path d="M 20 25 C 40 25, 40 15, 50 15" fill="none" stroke="#a855f7" stroke-width="0.5" class="opacity-0 group-hover:opacity-100 transition-all duration-700 delay-100 drop-shadow-[0_0_8px_rgba(168,85,247,0.8)]" />
                    <path d="M 20 25 C 40 25, 40 35, 50 35" fill="none" stroke="#a855f7" stroke-width="0.5" class="opacity-0 group-hover:opacity-100 transition-all duration-700 delay-200 drop-shadow-[0_0_8px_rgba(168,85,247,0.8)]" />
                    <path d="M 60 15 C 70 15, 75 25, 80 25" fill="none" stroke="#a855f7" stroke-width="0.5" class="opacity-0 group-hover:opacity-100 transition-all duration-700 delay-300 drop-shadow-[0_0_8px_rgba(168,85,247,0.8)]" />
                    <path d="M 60 35 C 70 35, 75 25, 80 25" fill="none" stroke="#ec4899" stroke-width="0.5" class="opacity-0 group-hover:opacity-100 transition-all duration-700 delay-400 drop-shadow-[0_0_8px_rgba(236,72,153,0.8)]" />
                 </svg>
                 
                 <div class="relative w-full h-full z-10">
                    <!-- Webhook Node -->
                    <div class="absolute left-[10%] top-1/2 -translate-y-1/2 w-14 h-14 rounded bg-[#0A0A0A] border border-[#333] flex items-center justify-center shadow-lg group-hover:border-purple-500/50 transition-colors duration-500">
                      <span class="text-[10px] font-mono text-gray-400">WHWK</span>
                    </div>

                    <!-- AI Node (Top) -->
                    <div class="absolute left-[50%] top-[20%] -translate-x-1/2 -translate-y-1/2 w-20 h-10 rounded bg-[#0A0A0A] border border-[#333] flex items-center justify-center shadow-lg group-hover:border-purple-500/50 transition-colors duration-500">
                      <span class="text-[10px] font-mono text-gray-400">OpenAI</span>
                    </div>

                    <!-- DB Node (Bottom) -->
                    <div class="absolute left-[50%] top-[80%] -translate-x-1/2 -translate-y-1/2 w-20 h-10 rounded bg-[#0A0A0A] border border-[#333] flex items-center justify-center shadow-lg group-hover:border-purple-500/50 transition-colors duration-500">
                      <span class="text-[10px] font-mono text-gray-400">Postgres</span>
                    </div>

                    <!-- CRM Node (Output) -->
                    <div class="absolute right-[10%] top-1/2 -translate-y-1/2 w-14 h-14 rounded bg-purple-500/10 border border-purple-500/30 flex flex-col items-center justify-center shadow-[0_0_20px_rgba(168,85,247,0.1)] group-hover:shadow-[0_0_30px_rgba(168,85,247,0.3)] transition-all duration-500">
                      <span class="text-[10px] font-mono text-purple-400 font-bold tracking-widest">CRM</span>
                    </div>
                 </div>

              </div>
              
            </div>
          </div>
          
        </div>
      </section>

      <!-- AuraSync Sticky Scroll Case -->
      <section class="flex flex-col lg:flex-row gap-16 lg:gap-24 relative items-start w-full">
        
        <!-- Left: Sticky Sidebar -->
        <div class="w-full lg:w-1/3 lg:sticky lg:top-32 flex flex-col z-10">
          <span class="text-xs uppercase tracking-widest text-[#61dafb] font-bold mb-4 font-mono">Native iOS/Android</span>
          <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-8 tracking-tight">AuraSync</h2>
          
          <div class="h-[1px] w-full bg-[#1A1A1A] mb-8"></div>
          
          <div class="mb-8">
             <h4 class="text-white font-bold mb-3 uppercase tracking-wider text-sm">The Challenge</h4>
             <p class="text-gray-400 font-light leading-relaxed">
               Deliver an ultra-fluid native experience, from onboarding to daily continuous use. The primary goal was to blur the line between local rendering and remote data fetching.
             </p>
          </div>

          <div class="mb-8">
             <h4 class="text-white font-bold mb-3 uppercase tracking-wider text-sm">The Stack</h4>
             <div class="flex gap-3 items-center flex-wrap">
                <span class="px-4 py-1.5 bg-[#111111] border border-[#222] rounded-full text-xs text-white font-mono shadow-sm flex items-center gap-2">
                  <span class="w-1.5 h-1.5 rounded-full bg-[#61dafb]"></span> React Native
                </span>
             </div>
          </div>

          <div>
             <h4 class="text-white font-bold mb-3 uppercase tracking-wider text-sm">The Outcome</h4>
             <p class="text-gray-400 font-light leading-relaxed text-[#0ea5e9]">
               World-class UI/UX paired with a lightweight, responsive backend. Delivered an App Store and Google Play verified binary within aggressive timelines.
             </p>
          </div>
        </div>

        <!-- Right: Scrolling Bento Content -->
        <div class="w-full lg:w-2/3 flex flex-col gap-8">
          
          <!-- Box 1: Isometric Mockup -->
          <div class="w-full rounded-[32px] border border-[#1A1A1A] bg-[#050505] min-h-[600px] p-8 md:p-12 flex flex-col relative overflow-hidden group perspective-[2000px]">
            <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-sky-900/10 via-[#050505] to-[#050505] pointer-events-none opacity-50 group-hover:opacity-100 transition-opacity duration-700"></div>
            
            <h3 class="text-xl font-bold text-white mb-6 relative z-30 opacity-30">01 / Isometric Mockups</h3>
            
            <div class="flex-1 w-full flex items-center justify-center relative z-10 pt-12 transform-style-3d">
               <!-- Isometric Scene Container -->
               <div class="relative w-[300px] h-[500px] flex items-center justify-center transform transition-transform duration-1000 rotate-[45deg] -rotate-x-[60deg] skew-x-[15deg] group-hover:-translate-y-8 group-hover:scale-[1.05]">
                  
                  <!-- Device 3 (Bottom) -->
                  <div class="absolute top-24 -left-24 w-[240px] h-[500px] bg-[#0A0A0A] border-[8px] border-[#111] rounded-[40px] shadow-[0_40px_100px_rgba(0,0,0,0.8)] flex flex-col p-4 opacity-40 group-hover:opacity-30 group-hover:translate-x-4 group-hover:-translate-y-4 transition-all duration-1000 delay-200">
                    <div class="w-1/2 h-6 mx-auto bg-[#000] rounded-b-[12px] mb-4"></div>
                    <div class="flex-1 w-full flex items-center justify-center">
                    </div>
                  </div>

                  <!-- Device 2 (Middle) -->
                  <div class="absolute top-12 -left-12 w-[240px] h-[500px] bg-[#0A0A0A] border-[8px] border-[#1A1A1A] rounded-[40px] shadow-[0_20px_50px_rgba(0,0,0,0.9)] flex flex-col p-4 opacity-70 group-hover:opacity-60 group-hover:translate-x-2 group-hover:-translate-y-2 transition-all duration-1000 delay-100 z-10">
                    <div class="w-1/2 h-6 mx-auto bg-[#000] rounded-b-[12px] mb-4"></div>
                    <div class="flex-1 w-full bg-[#111] border border-[#222] rounded-2xl flex flex-col gap-4 p-4">
                       <div class="w-full h-24 bg-[#1A1A1A] rounded-xl"></div>
                       <div class="w-full h-12 bg-[#1A1A1A] rounded-xl mt-auto"></div>
                    </div>
                  </div>

                  <!-- Device 1 (Top Hero) -->
                  <div class="absolute top-0 left-0 w-[240px] h-[500px] bg-[#000] border-[8px] border-[#222] rounded-[40px] shadow-[0_10px_30px_rgba(14,165,233,0.1)] group-hover:shadow-[0_20px_60px_rgba(14,165,233,0.3)] flex flex-col p-4 z-20 transition-all duration-1000">
                    <div class="w-1/2 h-6 mx-auto bg-[#1A1A1A] rounded-b-[12px] mb-4"></div>
                    <div class="flex-1 w-full bg-[#050505] border border-sky-500/20 rounded-2xl flex flex-col items-center justify-center gap-6 p-6">
                       <div class="w-16 h-16 rounded-full bg-sky-500/10 border border-sky-500/30 flex items-center justify-center relative">
                         <div class="absolute inset-0 rounded-full border border-sky-500/50 animate-[ping_2s_ease-out_infinite]"></div>
                         <div class="w-8 h-8 rounded-full bg-sky-500/20 font-mono text-[8px] text-sky-400 flex items-center justify-center">UI</div>
                       </div>
                       <div class="w-full space-y-2 mt-auto">
                          <div class="w-full h-8 bg-sky-500/5 rounded-lg border border-sky-500/10"></div>
                          <div class="w-full h-8 bg-sky-500/5 rounded-lg border border-sky-500/10"></div>
                       </div>
                    </div>
                  </div>

               </div>
            </div>
