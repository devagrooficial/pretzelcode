---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <Navbar />

  <!-- Hero -->
  <section class="relative w-full bg-[#080808] border-b border-[#1A1A1A] overflow-hidden flex flex-col items-center justify-center pt-32 pb-20 md:pt-40 md:pb-24 px-6">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-4xl h-96 bg-[radial-gradient(ellipse_at_top,rgba(172,72,26,0.14)_0%,transparent_70%)] pointer-events-none"></div>

    <div class="relative z-10 flex flex-col items-center text-center max-w-3xl">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white/5 border border-white/[0.08] backdrop-blur-md mb-8">
        <span class="w-1.5 h-1.5 rounded-full bg-primary animate-pulse"></span>
        <span class="text-xs text-neutral-400 tracking-wide font-medium uppercase">Contact</span>
      </div>

      <h1 class="text-5xl md:text-7xl font-medium tracking-tighter leading-[1.05] text-white">
        Let's talk SaaS.
      </h1>
      <p class="text-lg md:text-xl text-neutral-400 max-w-2xl mx-auto leading-relaxed mt-6">
        Whether you have a validated idea or a product already in the market, the conversation starts here. Every new build goes through our Equity Partnership review.
      </p>
    </div>
  </section>

  <main class="flex-1 w-full max-w-7xl mx-auto px-6 py-20 md:py-28 flex flex-col gap-20">

    <!-- Two paths -->
    <section class="grid grid-cols-1 md:grid-cols-2 gap-6">

      <!-- Path A: New SaaS build -->
      <a href="/partnership" class="group rounded-[24px] border border-[#1A1A1A] bg-[#050505] p-8 md:p-10 flex flex-col relative overflow-hidden hover:border-primary/40 transition-all duration-300">
        <div class="absolute top-0 right-0 w-64 h-64 bg-primary/[0.06] blur-[80px] rounded-full pointer-events-none"></div>
        <span class="text-[10px] font-mono uppercase tracking-widest text-primary mb-5">Build a SaaS with us</span>
        <h2 class="text-2xl md:text-3xl font-medium tracking-tight text-white mb-4">The Equity Partnership</h2>
        <p class="text-neutral-400 text-sm leading-relaxed mb-8 max-w-md">
          Our single engagement model for new products, by application only. You cover <span class="text-white font-medium">30% of the build</span>, we invest the remaining <span class="text-white font-medium">70%</span>, and you keep <span class="text-white font-medium">60% of the upside</span> — with a clear contract signed before development starts.
        </p>
        <span class="mt-auto inline-flex items-center gap-2 text-sm font-semibold text-white group-hover:text-primary transition-colors">
          Apply for Partnership
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="transform group-hover:translate-x-1 transition-transform"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </span>
      </a>

      <!-- Path B: Everything else -->
      <div class="rounded-[24px] border border-[#1A1A1A] bg-[#050505] p-8 md:p-10 flex flex-col relative overflow-hidden">
        <span class="text-[10px] font-mono uppercase tracking-widest text-neutral-500 mb-5">Everything else</span>
        <h2 class="text-2xl md:text-3xl font-medium tracking-tight text-white mb-4">General inquiries</h2>
        <p class="text-neutral-400 text-sm leading-relaxed mb-8 max-w-md">
          Ongoing product operation, maintenance contracts (monthly SLA), press, or anything that isn't a new build — use the form below or write to us directly.
        </p>
        <div class="mt-auto flex flex-col gap-3">
          <a href="mailto:hello@pretzelcode.com" class="inline-flex items-center gap-3 text-sm text-neutral-300 hover:text-white transition-colors">
            <span class="w-8 h-8 rounded-lg bg-[#0A0A0A] border border-[#1A1A1A] flex items-center justify-center text-primary">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            </span>
            hello@pretzelcode.com
          </a>
          <span class="inline-flex items-center gap-3 text-sm text-neutral-500">
            <span class="w-8 h-8 rounded-lg bg-[#0A0A0A] border border-[#1A1A1A] flex items-center justify-center text-neutral-600">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></svg>
            </span>
            Delaware, USA · EST/PST aligned
          </span>
        </div>
      </div>
    </section>

    <!-- Contact form -->
    <section class="w-full">
      <div class="max-w-2xl mb-12">
        <span class="text-primary font-semibold tracking-widest text-sm uppercase mb-4 block">Write to us</span>
        <h2 class="text-4xl md:text-5xl font-medium tracking-tighter text-white mb-6">Send a message.</h2>
        <p class="text-lg text-neutral-400 leading-relaxed">
          We reply to every serious message within two business days.
        </p>
      </div>

      <form id="contact-form" class="bg-[#050505] border border-[#1A1A1A] rounded-[32px] p-8 md:p-12 flex flex-col gap-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="flex flex-col gap-2">
            <label for="c-name" class="text-xs font-mono uppercase tracking-widest text-neutral-500">Full Name</label>
            <input id="c-name" name="name" type="text" required
              class="bg-[#0A0A0A] border border-[#1A1A1A] rounded-xl px-4 py-3.5 text-white placeholder:text-neutral-600 focus:outline-none focus:border-primary/50 transition-colors" placeholder="Jane Doe" />
          </div>
          <div class="flex flex-col gap-2">
            <label for="c-email" class="text-xs font-mono uppercase tracking-widest text-neutral-500">Email</label>
            <input id="c-email" name="email" type="email" required
              class="bg-[#0A0A0A] border border-[#1A1A1A] rounded-xl px-4 py-3.5 text-white placeholder:text-neutral-600 focus:outline-none focus:border-primary/50 transition-colors" placeholder="jane@company.com" />
          </div>
        </div>

        <div class="flex flex-col gap-2">
          <label for="c-topic" class="text-xs font-mono uppercase tracking-widest text-neutral-500">Topic</label>
          <select id="c-topic" name="topic" required
            class="bg-[#0A0A0A] border border-[#1A1A1A] rounded-xl px-4 py-3.5 text-white focus:outline-none focus:border-primary/50 transition-colors appearance-none">
            <option value="" disabled selected>Select one</option>
            <option value="New SaaS build (Equity Partnership)">New SaaS build (Equity Partnership)</option>
            <option value="Ongoing support / SLA">Ongoing support / monthly SLA</option>
            <option value="Existing product takeover">Existing product takeover</option>
            <option value="Other">Other</option>
          </select>
        </div>

        <div class="flex flex-col gap-2">
          <label for="c-message" class="text-xs font-mono uppercase tracking-widest text-neutral-500">Message</label>
          <textarea id="c-message" name="message" rows="6" required
            class="bg-[#0A0A0A] border border-[#1A1A1A] rounded-xl px-4 py-3.5 text-white placeholder:text-neutral-600 focus:outline-none focus:border-primary/50 transition-colors resize-none"
            placeholder="Tell us about your product, where it stands, and what you need."></textarea>
        </div>

        <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mt-2">
          <p class="text-xs text-neutral-600 max-w-sm leading-relaxed">
            Submitting opens your email client with the message pre-filled, addressed to our team.
          </p>
          <button type="submit"
            class="w-full sm:w-auto px-8 py-4 bg-primary text-white font-bold rounded-full hover:bg-primary-hover transition-all duration-300 shadow-[0_0_20px_var(--color-primary-glow)] hover:shadow-[0_0_35px_var(--color-primary-glow)] hover:-translate-y-0.5 shrink-0">
            Send Message
          </button>
        </div>
      </form>
    </section>

  </main>

  <Footer />

  <script>
    document.addEventListener('astro:page-load', () => {
      const form = document.getElementById('contact-form') as HTMLFormElement | null;
      if (!form) return;

      form.addEventListener('submit', (e) => {
        e.preventDefault();

        const data = new FormData(form);
        const name = String(data.get('name') || '');
        const email = String(data.get('email') || '');
        const topic = String(data.get('topic') || '');
        const message = String(data.get('message') || '');

        const subject = `Contact — ${topic}`;
        const body =
          `Name: ${name}\n` +
          `Email: ${email}\n` +
          `Topic: ${topic}\n\n` +
          `Message:\n${message}`;

        window.location.href = `mailto:hello@pretzelcode.com?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
      });
    });
  </script>
</Layout>
