---
// Modular Bento Grid Skeleton mapping to a robust 12-col layout
---

<style>
  /* Noise Overlay Filter Definition */
  .noise-bg {
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
    opacity: 0.04;
    pointer-events: none;
    mix-blend-mode: overlay;
  }
  
  /* Initial hidden state for observer */
  .bento-card {
    opacity: 0;
    transform: translateY(40px);
    transition: all 0.8s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  
  /* Trigger class applied via JS */
  .bento-card.in-view {
    opacity: 1;
    transform: translateY(0);
  }

  /* Spotlight Glow Layer */
  .bento-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
      800px circle at var(--mouse-x, 0) var(--mouse-y, 0),
      var(--color-primary-glow),
      transparent 40%
    );
    opacity: 0;
    transition: opacity 0.5s ease;
    pointer-events: none;
    z-index: 1;
  }

  .bento-card:hover::before {
    opacity: 1;
  }
</style>

<section id="bento-grid-container" class="grid grid-cols-1 md:grid-cols-4 gap-6 w-full">
  
  <!-- Row 2 -->
  <!-- Box 3 (4 col): Services -->
  <div class="bento-card col-span-1 md:col-span-4 rounded-[24px] border border-[#1A1A1A] bg-[#050505] p-8 md:p-10 relative overflow-hidden flex flex-col" style="transition-delay: 50ms;">
    <div class="absolute inset-0 z-0 noise-bg opacity-[0.03]"></div>
    
    <div class="relative z-10 w-full h-full flex flex-col">
      <span class="text-primary font-semibold tracking-widest uppercase text-xs mb-8 font-mono">Services</span>

      <!-- SaaS Development -->
      <a href="/expertise" class="group/row flex items-center justify-between border-b border-[#1A1A1A] py-5 cursor-pointer hover:border-primary/30 transition-all duration-300 relative overflow-hidden">
        <div class="flex items-center gap-4">
          <div class="w-8 h-8 rounded-lg bg-[#0A0A0A] border border-[#1A1A1A] flex items-center justify-center text-neutral-700 group-hover/row:text-primary group-hover/row:border-primary/30 transition-all duration-300">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
          </div>
          <span class="text-base font-medium text-neutral-300 group-hover/row:text-white transition-colors duration-200">SaaS Development</span>
        </div>
        <!-- Ghost phone icon appears on hover -->
        <div class="flex items-center gap-3">
          <svg width="14" height="22" viewBox="0 0 14 22" fill="none" class="text-primary/0 group-hover/row:text-primary/30 transition-all duration-500 -translate-x-4 group-hover/row:translate-x-0" stroke="currentColor" stroke-width="1.5"><rect x="1" y="1" width="12" height="20" rx="2"/><circle cx="7" cy="17" r="1" fill="currentColor" stroke="none"/></svg>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-neutral-600 group-hover/row:text-white transform group-hover/row:translate-x-1 transition-all duration-300"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </div>
      </a>

      <!-- App Development -->
      <a href="/expertise" class="group/row flex items-center justify-between border-b border-[#1A1A1A] py-5 cursor-pointer hover:border-primary/30 transition-all duration-300 relative overflow-hidden">
        <div class="flex items-center gap-4">
          <div class="w-8 h-8 rounded-lg bg-[#0A0A0A] border border-[#1A1A1A] flex items-center justify-center text-neutral-700 group-hover/row:text-[#61DAFB] group-hover/row:border-[#61DAFB]/30 transition-all duration-300">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="5" y="2" width="14" height="20" rx="2"/><circle cx="12" cy="17" r="1" fill="currentColor" stroke="none"/></svg>
          </div>
          <span class="text-base font-medium text-neutral-300 group-hover/row:text-white transition-colors duration-200">App Development</span>
        </div>
        <div class="flex items-center gap-3">
          <svg width="20" height="20" viewBox="-11.5 -10.23174 23 20.46348" class="text-[#61DAFB]/0 group-hover/row:text-[#61DAFB]/25 transition-all duration-500 -translate-x-4 group-hover/row:translate-x-0" stroke="currentColor" stroke-width="1" fill="none"><circle cx="0" cy="0" r="2.05" fill="currentColor"/><ellipse rx="11" ry="4.2"/><ellipse rx="11" ry="4.2" transform="rotate(60)"/><ellipse rx="11" ry="4.2" transform="rotate(120)"/></svg>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-neutral-600 group-hover/row:text-white transform group-hover/row:translate-x-1 transition-all duration-300"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </div>
      </a>

      <!-- Web Development -->
      <a href="/expertise" class="group/row flex items-center justify-between py-5 cursor-pointer hover:border-primary/30 transition-all duration-300 relative overflow-hidden mt-auto">
        <div class="flex items-center gap-4">
          <div class="w-8 h-8 rounded-lg bg-[#0A0A0A] border border-[#1A1A1A] flex items-center justify-center text-neutral-700 group-hover/row:text-neutral-300 group-hover/row:border-neutral-600/30 transition-all duration-300">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          </div>
          <span class="text-base font-medium text-neutral-300 group-hover/row:text-white transition-colors duration-200">Web Development</span>
        </div>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-neutral-600 group-hover/row:text-white transform group-hover/row:translate-x-1 transition-all duration-300"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
  </div>

  <!-- Row 3 -->
  <!-- Box 5 (2 col): Operations -->
  <div class="bento-card col-span-1 md:col-span-2 rounded-[24px] border border-[#1A1A1A] bg-[#050505] p-8 md:p-10 relative overflow-hidden flex flex-col" style="transition-delay: 100ms;">
    <div class="absolute inset-0 z-0 noise-bg opacity-[0.03]"></div>

    <div class="relative z-10 flex flex-col h-full">
      <span class="text-primary font-semibold tracking-widest uppercase text-xs mb-6 font-mono">Operations</span>
      <h3 class="text-xl font-semibold text-white mb-1">Systematized for Speed</h3>
      <p class="text-sm text-neutral-500 mb-6 leading-relaxed max-w-sm">Python or Node.js microservices, chosen based on project complexity, orchestrating complex processes and running silently in the background at bare metal speed.</p>

      <!-- Microservices pipeline SVG -->
      <div class="flex-1 bg-[#030303] border border-[#1A1A1A] rounded-xl overflow-hidden relative mt-auto">
        <svg class="w-full h-full" viewBox="0 0 480 180" fill="none" xmlns="http://www.w3.org/2000/svg">
          <style>
            .ms-flow { stroke-dasharray: 6 10; animation: msStream 8s linear infinite; }
            .ms-flow-slow { stroke-dasharray: 6 10; animation: msStream 12s linear infinite; }
            .ms-flow-fast { stroke-dasharray: 4 8; animation: msStream 5s linear infinite; }
            @keyframes msStream { from { stroke-dashoffset: 160; } to { stroke-dashoffset: 0; } }
            .ms-node-pulse { animation: msPulse 2.5s ease-in-out infinite alternate; }
            .ms-node-pulse-slow { animation: msPulse 4s ease-in-out infinite alternate; }
            @keyframes msPulse {
              from { filter: drop-shadow(0 0 2px rgba(172,72,26,0.3)); }
              to { filter: drop-shadow(0 0 10px rgba(172,72,26,0.9)); }
            }
          </style>

          <!-- Static base paths -->
          <path d="M 90 90 C 130 90 150 50 190 50" stroke="#1e1e1e" stroke-width="1.5"/>
          <path d="M 90 90 C 130 90 150 90 190 90" stroke="#1e1e1e" stroke-width="1.5"/>
          <path d="M 90 90 C 130 90 150 130 190 130" stroke="#1e1e1e" stroke-width="1.5"/>
          <path d="M 230 50 C 270 50 290 70 330 70" stroke="#1e1e1e" stroke-width="1.5"/>
          <path d="M 230 90 C 270 90 290 70 330 70" stroke="#1e1e1e" stroke-width="1.5"/>
          <path d="M 230 130 C 270 130 300 110 330 110" stroke="#1e1e1e" stroke-width="1.5"/>
          <path d="M 370 70 C 410 70 430 90 450 90" stroke="#1e1e1e" stroke-width="1.5"/>
          <path d="M 370 110 C 410 110 430 90 450 90" stroke="#1e1e1e" stroke-width="1.5"/>

          <!-- Animated flow lines -->
          <path class="ms-flow" d="M 90 90 C 130 90 150 50 190 50" stroke="#AC481A" stroke-width="1.5" stroke-linecap="round"/>
          <path class="ms-flow-slow" d="M 90 90 C 130 90 150 90 190 90" stroke="#AC481A" stroke-width="1.5" stroke-linecap="round"/>
          <path class="ms-flow-fast" d="M 90 90 C 130 90 150 130 190 130" stroke="#AC481A" stroke-width="1.5" stroke-linecap="round"/>
          <path class="ms-flow" d="M 230 50 C 270 50 290 70 330 70" stroke="#AC481A" stroke-width="1.5" stroke-linecap="round"/>
          <path class="ms-flow-fast" d="M 230 90 C 270 90 290 70 330 70" stroke="#AC481A" stroke-width="1.5" stroke-linecap="round"/>
          <path class="ms-flow-slow" d="M 230 130 C 270 130 300 110 330 110" stroke="#AC481A" stroke-width="1.5" stroke-linecap="round"/>
          <path class="ms-flow" d="M 370 70 C 410 70 430 90 450 90" stroke="#AC481A" stroke-width="1.5" stroke-linecap="round"/>
          <path class="ms-flow-slow" d="M 370 110 C 410 110 430 90 450 90" stroke="#AC481A" stroke-width="1.5" stroke-linecap="round"/>

          <!-- Input node -->
          <rect x="55" y="75" width="30" height="30" rx="6" fill="#0A0A0A" stroke="#2a2a2a" stroke-width="1.5"/>
          <text x="70" y="94" text-anchor="middle" fill="#555" font-size="9" font-family="monospace">IN</text>

          <!-- Middle nodes (services) -->
          <rect x="190" y="36" width="40" height="28" rx="5" fill="#0A0A0A" stroke="#AC481A" stroke-width="1.5" class="ms-node-pulse"/>
          <text x="210" y="53" text-anchor="middle" fill="#AC481A" font-size="7" font-family="monospace">PY svc</text>
          <rect x="190" y="76" width="40" height="28" rx="5" fill="#0A0A0A" stroke="#333" stroke-width="1.5"/>
          <text x="210" y="93" text-anchor="middle" fill="#555" font-size="7" font-family="monospace">queue</text>
          <rect x="190" y="116" width="40" height="28" rx="5" fill="#0A0A0A" stroke="#333" stroke-width="1.5"/>
          <text x="210" y="133" text-anchor="middle" fill="#555" font-size="7" font-family="monospace">worker</text>

          <!-- Aggregator nodes -->
          <rect x="330" y="56" width="40" height="28" rx="5" fill="#0A0A0A" stroke="#AC481A" stroke-width="1.5" class="ms-node-pulse-slow"/>
          <text x="350" y="73" text-anchor="middle" fill="#AC481A" font-size="7" font-family="monospace">router</text>
          <rect x="330" y="96" width="40" height="28" rx="5" fill="#0A0A0A" stroke="#333" stroke-width="1.5"/>
          <text x="350" y="113" text-anchor="middle" fill="#555" font-size="7" font-family="monospace">cache</text>

          <!-- Output node -->
          <circle cx="450" cy="90" r="18" fill="#0A0A0A" stroke="#AC481A" stroke-width="1.5" class="ms-node-pulse"/>
          <text x="450" y="94" text-anchor="middle" fill="#AC481A" font-size="8" font-family="monospace">OUT</text>
        </svg>
      </div>
    </div>
  </div>

  <!-- Box 6 (2 col): Headquarters / Globe -->
  <div class="bento-card col-span-1 md:col-span-2 rounded-[24px] border border-[#1A1A1A] bg-[#050505] relative overflow-hidden flex flex-col min-h-[360px]" style="transition-delay: 200ms;">
    <div class="absolute inset-0 z-0 noise-bg opacity-[0.03]"></div>

    <!-- Globe SVG background -->
    <div class="absolute inset-0 flex items-center justify-center opacity-40 pointer-events-none">
      <svg viewBox="0 0 400 400" class="w-[600px] h-[600px] -translate-y-16" fill="none" xmlns="http://www.w3.org/2000/svg">
        <style>
          .globe-ping { animation: globePing 3s ease-out infinite; }
          .globe-ping-2 { animation: globePing 3s ease-out infinite 1.5s; }
          .fly-arc { stroke-dasharray: 5 8; stroke-linecap: round; animation: flyArc 8s linear infinite; }
          @keyframes globePing {
            0% { r: 4; opacity: 1; }
            100% { r: 22; opacity: 0; }
          }
          @keyframes flyArc { from { stroke-dashoffset: 100; } to { stroke-dashoffset: 0; } }
        </style>

        <!-- Globe circle -->
        <circle cx="200" cy="200" r="160" stroke="#1a1a1a" stroke-width="1.5"/>

        <!-- Latitude lines -->
        <ellipse cx="200" cy="200" rx="160" ry="50" stroke="#141414" stroke-width="1"/>
        <ellipse cx="200" cy="200" rx="160" ry="100" stroke="#141414" stroke-width="1"/>
        <ellipse cx="200" cy="170" rx="155" ry="35" stroke="#141414" stroke-width="0.8"/>
        <ellipse cx="200" cy="230" rx="155" ry="35" stroke="#141414" stroke-width="0.8"/>

        <!-- Longitude lines -->
        <path d="M 200 40 C 250 90 250 310 200 360" stroke="#141414" stroke-width="1"/>
        <path d="M 200 40 C 150 90 150 310 200 360" stroke="#141414" stroke-width="1"/>
        <path d="M 200 40 C 280 100 280 300 200 360" stroke="#141414" stroke-width="1"/>
        <path d="M 200 40 C 120 100 120 300 200 360" stroke="#141414" stroke-width="1"/>
        <line x1="200" y1="40" x2="200" y2="360" stroke="#141414" stroke-width="1"/>
        <line x1="40" y1="200" x2="360" y2="200" stroke="#141414" stroke-width="0.8"/>

        <!-- US landmass abstract -->
        <path d="M 100 165 C 108 155 125 150 145 148 C 165 146 185 155 200 160 C 215 165 230 162 245 158 C 255 164 258 175 252 188 C 245 200 232 208 218 212 C 200 218 178 215 160 208 C 140 200 118 190 108 178 Z" fill="#111111" stroke="#1E1E1E" stroke-width="1"/>

        <!-- Arc path (SF to DE) -->
        <path d="M 128 182 C 150 145 230 145 240 178" stroke="#222" stroke-width="1.5"/>
        <path class="fly-arc" d="M 128 182 C 150 145 230 145 240 178" stroke="#AC481A" stroke-width="1.5"/>

        <!-- San Francisco ping -->
        <circle cx="128" cy="182" r="3" fill="#AC481A"/>
        <circle cx="128" cy="182" r="4" stroke="#AC481A" stroke-width="1" fill="transparent" class="globe-ping"/>

        <!-- Delaware ping -->
        <circle cx="240" cy="178" r="3" fill="#AC481A"/>
        <circle cx="240" cy="178" r="4" stroke="#AC481A" stroke-width="1" fill="transparent" class="globe-ping-2"/>
      </svg>
    </div>

    <!-- Gradient fade bottom -->
    <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-[#050505] to-transparent z-10 pointer-events-none"></div>

    <!-- Content anchored bottom -->
    <div class="relative z-20 mt-auto p-8 md:p-10">
      <span class="text-primary font-semibold tracking-widest uppercase text-xs font-mono block mb-3">US-Based HQ</span>
      <h3 class="text-xl font-semibold text-white mb-2 leading-snug">US Timezone Aligned.<br/>Silicon Valley Standard.</h3>
      <p class="text-sm text-neutral-500 max-w-xs leading-relaxed">Headquartered in Delaware. We operate on EST/PST for critical syncs, eliminating every geographic objection.</p>
      
      <!-- Timezone Badges -->
      <div class="flex items-center gap-3 mt-5">
        <div class="flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-[#0A0A0A] border border-[#1A1A1A]">
          <span class="w-1.5 h-1.5 rounded-full bg-primary animate-pulse"></span>
          <span class="text-[10px] text-neutral-400 font-mono">EST</span>
        </div>
        <div class="flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-[#0A0A0A] border border-[#1A1A1A]">
          <span class="w-1.5 h-1.5 rounded-full bg-neutral-600"></span>
          <span class="text-[10px] text-neutral-400 font-mono">PST</span>
        </div>
        <span class="text-[10px] text-neutral-700 font-mono">Delaware, USA</span>
      </div>
    </div>
  </div>

</section>

<script>
  document.addEventListener("astro:page-load", () => {
    // Spotlight Logic
    const gridContainer = document.getElementById("bento-grid-container");
    if (gridContainer) {
        gridContainer.addEventListener("mousemove", (e) => {
            const cards = gridContainer.querySelectorAll(".bento-card");
            for (const card of cards) {
                const rect = card.getBoundingClientRect();
                const x = e.clientX - rect.left;
                const y = e.clientY - rect.top;
                card.style.setProperty("--mouse-x", `${x}px`);
                card.style.setProperty("--mouse-y", `${y}px`);
            }
        });
    }

    const cards = document.querySelectorAll('.bento-card');
    
    if (cards.length === 0) return;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('in-view');
          observer.unobserve(entry.target);
        }
      });
    }, {
      root: null,
      threshold: 0.1,
      rootMargin: "0px 0px -50px 0px"
    });

    cards.forEach((card) => {
      observer.observe(card);
    });
  });
</script>
