<script>
  document.addEventListener("astro:page-load", () => {
    // Spotlight Logic
    const gridContainer = document.getElementById("bento-grid-container");
    if (gridContainer) {
        gridContainer.addEventListener("mousemove", (e) => {
            const cards = gridContainer.querySelectorAll(".bento-card");
            for (const card of cards) {
                const rect = card.getBoundingClientRect();
                const x = e.clientX - rect.left;
                const y = e.clientY - rect.top;
                card.style.setProperty("--mouse-x", `${x}px`);
                card.style.setProperty("--mouse-y", `${y}px`);
            }
        });
    }

    const cards = document.querySelectorAll('.bento-card');
    
    if (cards.length === 0) return;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('in-view');
          observer.unobserve(entry.target);
        }
      });
    }, {
      root: null,
      threshold: 0.1,
      rootMargin: "0px 0px -50px 0px"
    });

    cards.forEach((card) => {
      observer.observe(card);
    });

    // Carousel dot indicator sync
    const carousel = document.getElementById('portfolio-carousel');
    const dots = document.querySelectorAll('.carousel-dot');
    if (carousel && dots.length) {
      const slides = carousel.querySelectorAll('[class*="snap-start"]');
      const dotObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const idx = Array.from(slides).indexOf(entry.target);
            dots.forEach((d, i) => {
              d.classList.toggle('bg-white', i === idx);
              d.classList.toggle('bg-neutral-700', i !== idx);
              d.classList.toggle('w-3', i === idx);
              d.classList.toggle('w-1.5', i !== idx);
            });
          }
        });
      }, { root: carousel, threshold: 0.6 });
      slides.forEach(s => dotObserver.observe(s));
    }
    // Terminal live metrics
    const liveValEl = document.getElementById('live-val');
    const liveArrEl = document.getElementById('live-arr');
    const liveMrrEl = document.getElementById('live-mrr');
    const liveSyncEl = document.getElementById('live-sync');

    const fmt = (n) => n.toLocaleString();

    if (liveValEl) {
      let val = 12450, arr = 47200, mrr = 3933, syncSecs = 0;
      setInterval(() => {
        val += Math.floor(Math.random() * 80) - 20;
        arr += Math.floor(Math.random() * 200) - 50;
        mrr = Math.round(arr / 12);
        syncSecs = 0;
        liveValEl.textContent = fmt(val);
        if (liveArrEl) liveArrEl.textContent = fmt(arr);
        if (liveMrrEl) liveMrrEl.textContent = fmt(mrr);
        if (liveSyncEl) liveSyncEl.textContent = '0s ago';
      }, 2400);
      // sync timer counts up
      setInterval(() => {
        if (!liveSyncEl) return;
        const current = parseInt(liveSyncEl.textContent) || 0;
        liveSyncEl.textContent = `${current + 1}s ago`;
      }, 1000);
    }
  });
</script>
