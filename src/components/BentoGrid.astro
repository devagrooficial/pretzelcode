---
// Modular Bento Grid Skeleton mapping to a robust 12-col layout
---

<style>
  /* Noise Overlay Filter Definition */
  .noise-bg {
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
    opacity: 0.04;
    pointer-events: none;
    mix-blend-mode: overlay;
  }
  
  /* Initial hidden state for observer */
  .bento-card {
    opacity: 0;
    transform: translateY(40px);
    transition: all 0.8s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  
  /* Trigger class applied via JS */
  .bento-card.in-view {
    opacity: 1;
    transform: translateY(0);
  }

  /* Spotlight Glow Layer */
  .bento-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
      800px circle at var(--mouse-x, 0) var(--mouse-y, 0),
      var(--color-primary-glow),
      transparent 40%
    );
    opacity: 0;
    transition: opacity 0.5s ease;
    pointer-events: none;
    z-index: 1;
  }

  .bento-card:hover::before {
    opacity: 1;
  }

  /* Hide scrollbar for Chrome, Safari and Opera */
  .hide-scrollbar::-webkit-scrollbar {
    display: none;
  }
  /* Hide scrollbar for IE, Edge and Firefox */
  .hide-scrollbar {
    -ms-overflow-style: none;  /* IE and Edge */
    scrollbar-width: none;  /* Firefox */
  }
</style>

<section id="bento-grid-container" class="grid grid-cols-1 md:grid-cols-4 gap-6 w-full">
  
  <!-- Row 1 -->
  <!-- Box 1 (3 col): Portfolio -->
  <div class="bento-card col-span-1 md:col-span-3 rounded-[24px] overflow-hidden relative group p-[1px] bg-[#1A1A1A] hover:bg-gradient-to-br hover:from-primary/30 hover:via-[#2a2a2a] hover:to-[#1A1A1A] transition-all duration-500 min-h-[380px]">
    <div class="w-full h-full bg-[#050505] rounded-[23px] relative z-10 flex flex-col p-8 md:p-10">
      <div class="absolute inset-0 z-0 noise-bg opacity-[0.03] rounded-[23px]"></div>
      
      <div class="relative z-10 flex flex-col h-full w-full">
        <!-- Header -->
        <div class="flex items-center justify-between mb-8">
          <h3 class="text-sm font-semibold text-white uppercase tracking-widest font-mono">Selected Work</h3>
          <span class="text-xs text-neutral-600 font-mono">03 projects</span>
        </div>
        
        <!-- CSS Scroll-Snap Carousel -->
        <div id="portfolio-carousel" class="flex overflow-x-auto snap-x snap-mandatory hide-scrollbar gap-5 pb-2 mt-auto">
          
          <!-- NexusFlow -->
          <div class="min-w-full snap-start flex flex-col gap-5 group/item cursor-pointer" onclick="window.location='/work'">
            <!-- MacBook Frame -->
            <div class="w-full relative overflow-hidden rounded-xl border border-[#222] bg-[#0A0A0A] transition-all duration-500 group-hover/item:border-blue-500/30 group-hover/item:shadow-[0_0_30px_rgba(59,130,246,0.08)]">
              <!-- Screen bezel -->
              <div class="bg-[#111] px-3 pt-3 pb-0 rounded-t-xl flex items-center gap-1.5 border-b border-[#1a1a1a]">
                <span class="w-2.5 h-2.5 rounded-full bg-[#333]"></span>
                <span class="w-2.5 h-2.5 rounded-full bg-[#333]"></span>
                <span class="w-2.5 h-2.5 rounded-full bg-[#333]"></span>
                <span class="ml-auto text-[10px] text-neutral-700 font-mono">NexusFlow — Dashboard</span>
              </div>
              <!-- Screen content -->
              <div class="h-44 bg-[#06080F] overflow-hidden relative transition-transform duration-700 group-hover/item:scale-[1.03]">
                <!-- Dashboard mockup lines -->
                <div class="absolute inset-0 flex">
                  <div class="w-1/4 h-full bg-[#080C16] border-r border-[#111] p-3 flex flex-col gap-2">
                    <div class="w-full h-1.5 bg-blue-900/40 rounded"></div>
                    <div class="w-3/4 h-1.5 bg-[#1a1a2e] rounded"></div>
                    <div class="w-4/5 h-1.5 bg-[#1a1a2e] rounded mt-1"></div>
                    <div class="w-3/5 h-1.5 bg-blue-800/30 rounded"></div>
                    <div class="w-4/5 h-1.5 bg-[#1a1a2e] rounded"></div>
                    <div class="w-3/4 h-1.5 bg-[#1a1a2e] rounded"></div>
                  </div>
                  <div class="flex-1 p-4 flex flex-col gap-3">
                    <div class="grid grid-cols-3 gap-2">
                      <div class="h-12 bg-blue-900/20 rounded-lg border border-blue-800/20 flex items-center justify-center">
                        <div class="w-6 h-4 bg-blue-500/30 rounded"></div>
                      </div>
                      <div class="h-12 bg-[#0f111a] rounded-lg border border-[#1a1a2e]"></div>
                      <div class="h-12 bg-[#0f111a] rounded-lg border border-[#1a1a2e]"></div>
                    </div>
                    <div class="flex-1 bg-[#080c16]/80 rounded-lg border border-[#111] p-2">
                      <div class="w-full h-1.5 bg-blue-800/30 rounded mb-2"></div>
                      <div class="w-5/6 h-1 bg-[#1a1a2e] rounded mb-1.5"></div>
                      <div class="w-4/5 h-1 bg-[#1a1a2e] rounded mb-1.5"></div>
                      <div class="w-3/4 h-1 bg-[#1a1a2e] rounded"></div>
                    </div>
                  </div>
                </div>
                <!-- Blue accent glow -->
                <div class="absolute top-0 right-0 w-32 h-32 bg-blue-600/10 blur-2xl rounded-full"></div>
              </div>
            </div>
            <!-- Case info -->
            <div class="flex items-start justify-between">
              <div>
                <span class="text-[10px] font-mono text-blue-400 uppercase tracking-widest">B2B SaaS Engine</span>
                <h4 class="text-base font-semibold text-white mt-0.5">NexusFlow</h4>
                <p class="text-xs text-neutral-500 mt-1 max-w-xs">Enterprise operational suite with real-time reporting and high-volume data streams.</p>
              </div>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-neutral-700 group-hover/item:text-white shrink-0 mt-1 transition-colors"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </div>
          </div>

          <!-- VaultMetrics -->
          <div class="min-w-full snap-start flex flex-col gap-5 group/item cursor-pointer" onclick="window.location='/work'">
            <div class="w-full relative overflow-hidden rounded-xl border border-[#222] bg-[#0A0A0A] transition-all duration-500 group-hover/item:border-emerald-500/30 group-hover/item:shadow-[0_0_30px_rgba(16,185,129,0.08)]">
              <div class="bg-[#111] px-3 pt-3 pb-0 rounded-t-xl flex items-center gap-1.5 border-b border-[#1a1a1a]">
                <span class="w-2.5 h-2.5 rounded-full bg-[#333]"></span>
                <span class="w-2.5 h-2.5 rounded-full bg-[#333]"></span>
                <span class="w-2.5 h-2.5 rounded-full bg-[#333]"></span>
                <span class="ml-auto text-[10px] text-neutral-700 font-mono">VaultMetrics — Analytics</span>
              </div>
              <div class="h-44 bg-[#050F09] overflow-hidden relative transition-transform duration-700 group-hover/item:scale-[1.03]">
                <div class="absolute inset-0 p-4 flex flex-col gap-3">
                  <div class="flex gap-3">
                    <div class="flex-1 h-16 bg-emerald-900/20 rounded-lg border border-emerald-800/20 p-2">
                      <div class="w-8 h-1 bg-emerald-500/40 rounded mb-2"></div>
                      <div class="text-[18px] font-bold text-emerald-400/60 leading-none">$12.4k</div>
                    </div>
                    <div class="flex-1 h-16 bg-[#080f08] rounded-lg border border-[#111] p-2">
                      <div class="w-6 h-1 bg-[#1a2a1a] rounded mb-2"></div>
                      <div class="w-10 h-3 bg-[#1a2a1a] rounded"></div>
                    </div>
                    <div class="flex-1 h-16 bg-[#080f08] rounded-lg border border-[#111] p-2"></div>
                  </div>
                  <!-- Chart bars -->
                  <div class="flex-1 bg-[#050f09] rounded-lg border border-[#0d1f0d] p-3 flex items-end gap-1.5">
                    <div class="flex-1 bg-emerald-800/30 rounded-sm" style="height:40%"></div>
                    <div class="flex-1 bg-emerald-700/40 rounded-sm" style="height:65%"></div>
                    <div class="flex-1 bg-emerald-600/50 rounded-sm" style="height:50%"></div>
                    <div class="flex-1 bg-emerald-500/60 rounded-sm" style="height:80%"></div>
                    <div class="flex-1 bg-emerald-400/70 rounded-sm" style="height:95%"></div>
                    <div class="flex-1 bg-emerald-300/40 rounded-sm" style="height:70%"></div>
                    <div class="flex-1 bg-emerald-800/30 rounded-sm" style="height:45%"></div>
                  </div>
                </div>
                <div class="absolute top-0 left-0 w-32 h-32 bg-emerald-600/10 blur-2xl rounded-full"></div>
              </div>
            </div>
            <div class="flex items-start justify-between">
              <div>
                <span class="text-[10px] font-mono text-emerald-400 uppercase tracking-widest">Lead Gen Ecosystem</span>
                <h4 class="text-base font-semibold text-white mt-0.5">VaultMetrics</h4>
                <p class="text-xs text-neutral-500 mt-1 max-w-xs">Deep telemetry and monetization dashboards built for hyper-scaling revenue teams.</p>
              </div>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-neutral-700 group-hover/item:text-white shrink-0 mt-1 transition-colors"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </div>
          </div>

          <!-- AuraSync -->
          <div class="min-w-full snap-start flex flex-col gap-5 group/item cursor-pointer" onclick="window.location='/work'">
            <div class="w-full relative overflow-hidden rounded-xl border border-[#222] bg-[#0A0A0A] transition-all duration-500 group-hover/item:border-purple-500/30 group-hover/item:shadow-[0_0_30px_rgba(168,85,247,0.08)]">
              <div class="bg-[#111] px-3 pt-3 pb-0 rounded-t-xl flex items-center gap-1.5 border-b border-[#1a1a1a]">
                <span class="w-2.5 h-2.5 rounded-full bg-[#333]"></span>
                <span class="w-2.5 h-2.5 rounded-full bg-[#333]"></span>
                <span class="w-2.5 h-2.5 rounded-full bg-[#333]"></span>
                <span class="ml-auto text-[10px] text-neutral-700 font-mono">AuraSync — Mobile App</span>
              </div>
              <div class="h-44 bg-[#0A0610] overflow-hidden relative transition-transform duration-700 group-hover/item:scale-[1.03]">
                <div class="absolute inset-0 flex items-center justify-center gap-6 p-4">
                  <!-- Phone mockups side by side -->
                  <div class="w-20 h-36 bg-[#0d0816] border border-purple-900/30 rounded-2xl flex flex-col overflow-hidden">
                    <div class="h-2 bg-[#130d1e] border-b border-purple-900/20 flex justify-center items-center">
                      <div class="w-6 h-0.5 bg-[#2a1f3a] rounded"></div>
                    </div>
                    <div class="flex-1 p-1.5 flex flex-col gap-1">
                      <div class="w-full h-8 bg-purple-900/25 rounded-lg"></div>
                      <div class="w-full h-3 bg-[#1a1030] rounded"></div>
                      <div class="w-3/4 h-3 bg-[#1a1030] rounded"></div>
                      <div class="w-full h-8 bg-[#0d0816] border border-purple-900/20 rounded-lg mt-1"></div>
                    </div>
                  </div>
                  <div class="w-20 h-36 bg-[#0d0816] border border-purple-800/40 rounded-2xl flex flex-col overflow-hidden shadow-[0_0_20px_rgba(168,85,247,0.15)]">
                    <div class="h-2 bg-[#130d1e] border-b border-purple-900/20 flex justify-center items-center">
                      <div class="w-6 h-0.5 bg-[#2a1f3a] rounded"></div>
                    </div>
                    <div class="flex-1 p-1.5 flex flex-col gap-1">
                      <div class="w-full h-8 bg-purple-700/30 rounded-lg"></div>
                      <div class="w-full h-3 bg-purple-900/30 rounded"></div>
                      <div class="w-3/4 h-3 bg-[#1a1030] rounded"></div>
                      <div class="flex gap-1 mt-1">
                        <div class="flex-1 h-6 bg-purple-700/20 rounded"></div>
                        <div class="flex-1 h-6 bg-purple-600/30 rounded"></div>
                      </div>
                    </div>
                  </div>
                </div>
                <div class="absolute top-0 right-0 w-32 h-32 bg-purple-700/10 blur-2xl rounded-full"></div>
              </div>
            </div>
            <div class="flex items-start justify-between">
              <div>
                <span class="text-[10px] font-mono text-purple-400 uppercase tracking-widest">React Native App</span>
                <h4 class="text-base font-semibold text-white mt-0.5">AuraSync</h4>
                <p class="text-xs text-neutral-500 mt-1 max-w-xs">Cross-platform native experiences at 60fps, wrapping intense hardware integrations.</p>
              </div>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-neutral-700 group-hover/item:text-white shrink-0 mt-1 transition-colors"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </div>
          </div>

        </div>

        <!-- Carousel Dot Indicators -->
        <div id="portfolio-dots" class="flex items-center justify-center gap-2 mt-5">
          <span class="carousel-dot w-1.5 h-1.5 rounded-full bg-white transition-all duration-300"></span>
          <span class="carousel-dot w-1.5 h-1.5 rounded-full bg-neutral-700 transition-all duration-300"></span>
          <span class="carousel-dot w-1.5 h-1.5 rounded-full bg-neutral-700 transition-all duration-300"></span>
        </div>
      </div>
    </div>
  </div>

  <!-- Box 2 (1 col): The Stack -->
  <div class="bento-card col-span-1 md:col-span-1 rounded-[24px] border border-[#1A1A1A] bg-[#050505] p-7 relative overflow-hidden flex flex-col min-h-[380px]" style="transition-delay: 100ms;">
    <div class="absolute inset-0 z-0 noise-bg opacity-[0.03] rounded-[24px]"></div>
    <div class="relative z-10 h-full flex flex-col">
      <h4 class="text-xs uppercase tracking-widest text-primary font-mono mb-auto pb-6">Built for Scale</h4>
      
      <div class="flex flex-col gap-5">
        <!-- Python -->
        <div class="group/tech flex items-center gap-3 cursor-pointer">
          <div class="w-9 h-9 rounded-lg bg-[#0A0A0A] border border-[#1A1A1A] flex items-center justify-center text-neutral-600 transition-all duration-300 group-hover/tech:text-[#3776AB] group-hover/tech:border-[#3776AB]/30 group-hover/tech:shadow-[0_0_12px_rgba(55,118,171,0.2)]">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M14.25.18c.9.05 1.74.22 2.56.55.84.34 1.54.8 2.05 1.4.52.59.84 1.28.98 2.11.12.75.12 1.63.12 2.53v.53h-1.63v-.53c0-.85.01-1.68-.08-2.31-.1-.66-.35-1.16-.72-1.52-.39-.38-.9-.67-1.54-.85-.68-.19-1.5-.28-3.05-.28H11.8c-1.55 0-2.37.09-3.05.28-.64.18-1.15.47-1.54.85-.37.36-.62.86-.72 1.52-.09.63-.08 1.46-.08 2.31v4.3h8.33c1.78 0 3.03.14 4.04.53 1.05.42 1.83 1.05 2.44 1.88.62.83.96 1.8.19 3.01-.13.78-.18 1.6-.18 2.37v.88c0 .85-.01 1.68-.08 2.31-.1.66-.35 1.16-.72 1.52-.39.38-.9.67-1.54.85-.68.19-1.5.28-3.05.28h-3v-1.64h3c.85 0 1.68-.01 2.31-.08.66-.1 1.16-.35 1.52-.72.38-.39.67-.9.85-1.54.19-.68.28-1.5.28-3.05v-.88c0-.75 0-1.54-.12-2.31-.13-.76-.43-1.42-.91-1.92-.49-.52-1.12-.86-1.95-1.14-.85-.29-1.97-.39-3.8-.39H7.66c-1.78 0-3.03-.14-4.04-.53-1.05-.42-1.83-1.05-2.44-1.88-.62-.83-.96-1.8-.19-3.01.13-.78.18-1.6.18-2.37V6.77c0-.9 0-1.78.12-2.53.14-.83.46-1.52.98-2.11.51-.6 1.21-1.06 2.05-1.4.82-.33 1.66-.5 2.56-.55zM9.75 3.04a.97.97 0 1 0 0 1.94.97.97 0 0 0 0-1.94zm4.5 15.92a.97.97 0 1 0 0 1.94.97.97 0 0 0 0-1.94z"/></svg>
          </div>
          <span class="text-xs font-medium text-neutral-400 group-hover/tech:text-[#3776AB] transition-colors">Python</span>
        </div>
        <!-- Supabase -->
        <div class="group/tech flex items-center gap-3 cursor-pointer">
          <div class="w-9 h-9 rounded-lg bg-[#0A0A0A] border border-[#1A1A1A] flex items-center justify-center text-neutral-600 transition-all duration-300 group-hover/tech:text-[#3ECF8E] group-hover/tech:border-[#3ECF8E]/30 group-hover/tech:shadow-[0_0_12px_rgba(62,207,142,0.2)]">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12.02.32L1.87 11.45a.65.65 0 0 0 .48 1.1h7.82v10.98a.15.15 0 0 0 .26.1l11.7-12.83a.65.65 0 0 0-.48-1.1h-7.82V.43a.15.15 0 0 0-.25-.11z"/></svg>
          </div>
          <span class="text-xs font-medium text-neutral-400 group-hover/tech:text-[#3ECF8E] transition-colors">Supabase</span>
        </div>
        <!-- React Native -->
        <div class="group/tech flex items-center gap-3 cursor-pointer">
          <div class="w-9 h-9 rounded-lg bg-[#0A0A0A] border border-[#1A1A1A] flex items-center justify-center text-neutral-600 transition-all duration-300 group-hover/tech:text-[#61DAFB] group-hover/tech:border-[#61DAFB]/30 group-hover/tech:shadow-[0_0_12px_rgba(97,218,251,0.2)]">
            <svg width="20" height="20" viewBox="-11.5 -10.23174 23 20.46348" xmlns="http://www.w3.org/2000/svg">
              <circle cx="0" cy="0" r="2.05" fill="currentColor"/>
              <g stroke="currentColor" stroke-width="1" fill="none">
                <ellipse rx="11" ry="4.2"/>
                <ellipse rx="11" ry="4.2" transform="rotate(60)"/>
                <ellipse rx="11" ry="4.2" transform="rotate(120)"/>
              </g>
            </svg>
          </div>
          <span class="text-xs font-medium text-neutral-400 group-hover/tech:text-[#61DAFB] transition-colors">React Native</span>
        </div>
        <!-- Python Microservices -->
        <div class="group/tech flex items-center gap-3 cursor-pointer">
          <div class="w-9 h-9 rounded-lg bg-[#0A0A0A] border border-[#1A1A1A] flex items-center justify-center text-neutral-600 transition-all duration-300 group-hover/tech:text-[#AC481A] group-hover/tech:border-primary/30 group-hover/tech:shadow-[0_0_12px_var(--color-primary-glow)]">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="16" y="16" width="6" height="6" rx="1"/>
              <rect x="2" y="16" width="6" height="6" rx="1"/>
              <rect x="9" y="2" width="6" height="6" rx="1"/>
              <path d="M5 16v-3a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v3"/>
              <path d="M12 8v3"/>
            </svg>
          </div>
          <span class="text-xs font-medium text-neutral-400 group-hover/tech:text-[#AC481A] transition-colors">Microservices</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Row 2 -->
  <!-- Box 3 (2 col): Services -->
  <div class="bento-card col-span-1 md:col-span-2 rounded-[24px] border border-[#1A1A1A] bg-[#050505] p-8 md:p-10 relative overflow-hidden flex flex-col" style="transition-delay: 50ms;">
    <div class="absolute inset-0 z-0 noise-bg opacity-[0.03]"></div>
    
    <div class="relative z-10 w-full h-full flex flex-col">
      <span class="text-primary font-semibold tracking-widest uppercase text-xs mb-8 font-mono">Services</span>

      <!-- SaaS Development -->
      <a href="/expertise" class="group/row flex items-center justify-between border-b border-[#1A1A1A] py-5 cursor-pointer hover:border-primary/30 transition-all duration-300 relative overflow-hidden">
        <div class="flex items-center gap-4">
          <div class="w-8 h-8 rounded-lg bg-[#0A0A0A] border border-[#1A1A1A] flex items-center justify-center text-neutral-700 group-hover/row:text-primary group-hover/row:border-primary/30 transition-all duration-300">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
          </div>
          <span class="text-base font-medium text-neutral-300 group-hover/row:text-white transition-colors duration-200">SaaS Development</span>
