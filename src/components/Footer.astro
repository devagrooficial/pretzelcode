---
const currentYear = new Date().getFullYear();
---

<footer class="w-full bg-[#000000] border-t border-[#111111] pt-16 pb-8 mt-24">
  <div class="max-w-7xl mx-auto px-6 md:px-12 w-full">
    
    <!-- Top Grid -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 md:gap-8 mb-16">
      
      <!-- Brand & Mission -->
      <div class="col-span-1 md:col-span-1">
        <img src="/images/logoHorizontalwhite.png" alt="Pretzel Code" class="h-10 w-auto mb-4" />
        <p class="text-sm text-gray-400 max-w-xs">
          A high-performance software laboratory forging elite SaaS, web platforms, and mobile apps. Headquartered in Delaware.
        </p>
      </div>

      <!-- Main Navigation -->
      <div class="col-span-1 md:ml-auto">
        <h3 class="text-xs font-mono text-gray-500 uppercase tracking-widest mb-4">Platform</h3>
        <ul class="flex flex-col gap-3 text-sm text-gray-300">
          <li><a href="/work" class="hover:text-white transition-colors">Work</a></li>
          <li><a href="/expertise" class="hover:text-white transition-colors">Services</a></li>
          <li><a href="/backstage" class="hover:text-white transition-colors">Backstage</a></li>
          <li><a href="/company" class="hover:text-white transition-colors">Company</a></li>

        </ul>
      </div>

      <!-- Legal Navigation -->
      <div class="col-span-1 md:ml-auto">
        <h3 class="text-xs font-mono text-gray-500 uppercase tracking-widest mb-4">Legal</h3>
        <div class="flex flex-col gap-3 text-sm text-gray-300 items-start">
          <button id="btn-terms" class="hover:text-white transition-colors text-left">Terms of Service</button>
          <button id="btn-privacy" class="hover:text-white transition-colors text-left">Privacy Policy</button>
        </div>
      </div>

      <!-- C-Level Access / Platform Link -->
      <div class="col-span-1 md:flex md:justify-end">
        <div>
          <h3 class="text-xs font-mono text-gray-500 uppercase tracking-widest mb-4 md:text-right">Client Portal</h3>
          <a href="https://app.pretzelcode.com" target="_blank" class="inline-flex items-center gap-2 text-sm font-medium text-white hover:text-emerald-400 transition-colors">
            Log In
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
          </a>
        </div>
      </div>

    </div>

    <!-- Divider -->
    <div class="w-full h-[1px] bg-[#111111] mb-8"></div>

    <!-- Bottom Bar -->
    <div class="flex flex-col md:flex-row items-center justify-between gap-4 text-xs font-mono text-gray-500 uppercase tracking-widest">
      <p>&copy; {currentYear} Pretzel Code LLC.</p>
      <p class="text-gray-400">Crafted with precision.</p>
    </div>

  </div>
</footer>

<!-- ── Legal Modals ──────────────────────────────────────────────── -->

<!-- Terms Modal -->
<div id="modal-terms" class="fixed inset-0 z-[200] hidden items-center justify-center bg-black/90 backdrop-blur-md p-4 transition-opacity">
  <div class="w-full max-w-3xl max-h-[80vh] bg-[#050505] border border-[#1A1A1A] rounded-[24px] flex flex-col overflow-hidden">
    <!-- Header -->
    <div class="flex items-center justify-between p-6 border-b border-[#1A1A1A]">
      <h2 class="text-xl font-medium text-white">Terms of Service</h2>
      <button id="close-terms" class="text-neutral-500 hover:text-white transition-colors p-2" aria-label="Close">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>
    </div>
    <!-- Body -->
    <div class="overflow-y-auto p-8 text-sm text-neutral-400 space-y-6">
      <h3 class="text-white font-medium text-base">1. Acceptance of Terms</h3><p>By engaging Pretzel Code LLC (Delaware, US), accessing our Backstage, or utilizing our engineering services, you agree to these Terms. If you do not agree, do not use our services.</p><h3 class="text-white font-medium text-base">2. Intellectual Property & Code Ownership</h3><p>Upon full payment for custom engineering services, clients receive ownership of the final front-end and specific business logic. However, Pretzel Code LLC retains exclusive rights to its proprietary underlying architecture, Python microservices, and internal libraries (the "Alpha Architecture") used to accelerate development.</p><h3 class="text-white font-medium text-base">3. Subscription Services (The Backstage)</h3><p>The Backstage is a recurring subscription. You may cancel at any time. We do not provide refunds for partial billing periods. Access to internal telemetry and code is strictly confidential and may not be reproduced.</p><h3 class="text-white font-medium text-base">4. Limitation of Liability</h3><p>Our software and SaaS products are provided "as is". Under Delaware law, Pretzel Code LLC shall not be liable for any indirect, incidental, or consequential damages, including lost profits or data loss, arising from the use of our code or platforms.</p>
    </div>
  </div>
</div>

<!-- Privacy Modal -->
<div id="modal-privacy" class="fixed inset-0 z-[200] hidden items-center justify-center bg-black/90 backdrop-blur-md p-4 transition-opacity">
  <div class="w-full max-w-3xl max-h-[80vh] bg-[#050505] border border-[#1A1A1A] rounded-[24px] flex flex-col overflow-hidden">
    <!-- Header -->
    <div class="flex items-center justify-between p-6 border-b border-[#1A1A1A]">
      <h2 class="text-xl font-medium text-white">Privacy Policy</h2>
      <button id="close-privacy" class="text-neutral-500 hover:text-white transition-colors p-2" aria-label="Close">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>
    </div>
    <!-- Body -->
    <div class="overflow-y-auto p-8 text-sm text-neutral-400 space-y-6">
      <h3 class="text-white font-medium text-base">1. Information We Collect</h3><p>We collect personal data you provide directly (such as name and email) when booking an Architecture Audit, subscribing to The Backstage, or entering a contract. We also collect automated telemetry data to improve our SaaS products.</p><h3 class="text-white font-medium text-base">2. How We Use Your Data</h3><p>Data is used exclusively to deliver our engineering services, process transactions (via Stripe), and maintain our infrastructure. We do not sell your personal data to data brokers.</p><h3 class="text-white font-medium text-base">3. Third-Party Processors</h3><p>We utilize secure, industry-standard third-party services, including Supabase (Database/Auth) and Stripe (Payments), which have their own rigorous privacy and compliance standards.</p><h3 class="text-white font-medium text-base">4. Your Rights</h3><p>Depending on your location (including CCPA compliance for US residents), you may request access to, deletion of, or correction of your personal data by contacting our team directly.</p>
    </div>
  </div>
</div>

<script>
  document.addEventListener('astro:page-load', () => {
    const btnTerms = document.getElementById('btn-terms');
    const btnPrivacy = document.getElementById('btn-privacy');
    const modalTerms = document.getElementById('modal-terms');
    const modalPrivacy = document.getElementById('modal-privacy');
    const closeTerms = document.getElementById('close-terms');
    const closePrivacy = document.getElementById('close-privacy');

    // Open Modals
    if (btnTerms && modalTerms) {
      btnTerms.addEventListener('click', () => {
        modalTerms.classList.remove('hidden');
        modalTerms.classList.add('flex');
        document.body.style.overflow = 'hidden';
      });
    }

    if (btnPrivacy && modalPrivacy) {
      btnPrivacy.addEventListener('click', () => {
        modalPrivacy.classList.remove('hidden');
        modalPrivacy.classList.add('flex');
        document.body.style.overflow = 'hidden';
      });
    }

    // Close Functions
    const hideTerms = () => {
      if (modalTerms) {
        modalTerms.classList.add('hidden');
        modalTerms.classList.remove('flex');
        document.body.style.overflow = '';
      }
    };

    const hidePrivacy = () => {
      if (modalPrivacy) {
        modalPrivacy.classList.add('hidden');
        modalPrivacy.classList.remove('flex');
        document.body.style.overflow = '';
      }
    };

    // Close on X
    if (closeTerms) closeTerms.addEventListener('click', hideTerms);
    if (closePrivacy) closePrivacy.addEventListener('click', hidePrivacy);

    // Close on Backdrop Click
    if (modalTerms) {
      modalTerms.addEventListener('click', (e) => {
        if (e.target === modalTerms) hideTerms();
      });
    }
    if (modalPrivacy) {
      modalPrivacy.addEventListener('click', (e) => {
        if (e.target === modalPrivacy) hidePrivacy();
      });
    }
    
    // Close on Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        hideTerms();
        hidePrivacy();
      }
    });

  });
</script>
